<!DOCTYPE translationbundle>
<translationbundle lang="my">
<translation id="1026101648481255140">ထည့်သွင်းမှု ဆက်လုပ်ရန်</translation>
<translation id="1029669172902658969">&amp;ChromiumOS အပ်ဒိတ်လုပ်ရန်အတွက် ပြန်ဖွင့်ရန်</translation>
<translation id="1065672644894730302">သင့်စိတ်ကြိုက်များ ဖတ်၍မရပါ။

အချို့အင်္ဂရပ်များ မရရှိနိုင်ပါ၊ စိတ်ကြိုက်များသို့ ပြောင်းလဲခြင်းများ သိမ်းမည်မဟုတ်ပါ။</translation>
<translation id="4960963727707787489">ဒေတာပေါက်ကြားမှု၊ ဘေးကင်းမှုမရှိသော နောက်ဆက်တွဲနှင့် အခြားအန္တရာယ်များမှ သင့်ကိုလုံခြုံအောင် WEB3 DNA Browser က ကူညီပေးနိုင်သည်</translation>
<translation id="1018420750873862665">WEB3 DNA Browser သည် သင်၏ စကားဝှက်များကို တင်ပို့လိုသည်။ ၎င်းကို ခွင့်ပြုရန် သင်၏ Windows စကားဝှက်ကို ထည့်ပါ။</translation>
<translation id="8728335547814212082">WEB3 DNA Browser သည် သင်၏ မူရင်းဘရောင်ဇာဖြစ်သည်</translation>
<translation id="3462550327714525487">သင်၏စကားဝှက်များတွင် ဒေတာပေါက်ကြားမှုနှင့် အခြားသော လုံခြုံရေးပြဿနာများ ရှိ၊ မရှိ စစ်ဆေးရန် <ph name="BEGIN_LINK" />WEB3 DNA Browser သို့ လက်မှတ်ထိုးဝင်ပါ<ph name="END_LINK" />။</translation>
<translation id="4464481789599383598">WEB3 DNA Browser အကြောင်း</translation>
<translation id="1203500561924088507">ထည့်သွင်းသည့်အတွက် ကျေးဇူးတင်ပါသည်။ <ph name="BUNDLE_NAME" /> အသုံးမပြုမီ သင့်ဘရောင်ဇာကို ပြန်စရမည်။</translation>
<translation id="5978964989109500768">ဖွင့်ထားပါက WEB3 DNA Browser သည် အသုံးမပြုသည့်တဘ်များရှိ မှတ်ဉာဏ်ကို နေရာလွတ်ပြုလုပ်သည်။ ၎င်းက အသုံးပြုနေသည့်တဘ်နှင့် အခြားအက်ပ်များအား ကွန်ပျူတာရင်းမြစ် ပိုပေးပြီး WEB3 DNA Browser ကို မြန်ဆန်စေသည်။ အသုံးမပြုသည့်တဘ်များသို့ ပြန်သွားသောအခါ ၎င်းတို့က အလိုအလျောက် ပြန်လည်လုပ်ဆောင်လာမည်။ <ph name="BEGIN_LINK" />ပိုမိုလေ့လာရန်<ph name="END_LINK" /></translation>
<translation id="2556820941333974881">မှတ်ဉာဏ်ချွေတာစနစ်က WEB3 DNA Browser ကို ပိုမြန်စေသည်</translation>
<translation id="8674698533637405550">သင်၏ WEB3 DNA Browser ပရိုဖိုင်အသစ်ကို စနစ်ထည့်သွင်းပါ</translation>
<translation id="5897235607289042281">WEB3 DNA Browser ရှိ Google Assistant</translation>
<translation id="4011302926653396528">WEB3 DNA Browser က စကားဝှက်များကို ပြရန် ကြိုးစားနေသည်။</translation>
<translation id="7808556894409107558">သင်သည် WEB3 DNA Browser သို့ဝင်ရောက်ပြီးဖြစ်သည်!</translation>
<translation id="2448956114941459869">WEB3 DNA Browser ကို အကောင်းဆုံး အသုံးချနိုင်သည်</translation>
<translation id="6123758632973468022">WEB3 DNA Browser တဘ် မျှဝေခြင်း</translation>
<translation id="1232307829393891937">သင့်ပတ်ဝန်းကျင်၏ 3D မြေပုံ ပြုလုပ်ရန် WEB3 DNA Browser က သင့်ကင်မရာကို အသုံးပြုခွင့် လိုအပ်သည်</translation>
<translation id="5103307222334991576">{COUNT,plural, =0{အပ်ဒိတ်ကို အသုံးပြုနိုင်ရန်အတွက် WEB3 DNA Browser ကို ပြန်လည်စတင်ရန် သင်၏စီမံခန့်ခွဲသူက တောင်းဆိုထားပါသည်}=1{အပ်ဒိတ်ကို အသုံးပြုနိုင်ရန်အတွက် WEB3 DNA Browser ကို ပြန်လည်စတင်ရန် သင်၏စီမံခန့်ခွဲသူက တောင်းဆိုထားပါသည်။ သင်၏ရုပ်ဖျက် ဝင်ဒိုးကို ပြန်ဖွင့်မည် မဟုတ်ပါ။}other{အပ်ဒိတ်ကို အသုံးပြုနိုင်ရန်အတွက် WEB3 DNA Browser ကို ပြန်လည်စတင်ရန် သင်၏စီမံခန့်ခွဲသူက တောင်းဆိုထားပါသည်။ သင်၏ရုပ်ဖျက် ဝင်ဒိုး # ခုကို ပြန်ဖွင့်မည် မဟုတ်ပါ။}}</translation>
<translation id="7291131704197390431">အဓိကကျသော ကိုယ်ရေးအချက်အလက်နှင့် လုံခြုံရေး ထိန်းချုပ်မှုများကို WEB3 DNA Browser တွင် ကြည့်နိုင်သည်</translation>
<translation id="5962221630684419652">ဤအကောင့်ကို တစ်ကြိမ်သာအသုံးပြုလိုပါက WEB3 DNA Browser ဘရောင်ဇာတွင် <ph name="GUEST_LINK_BEGIN" />ဧည့်သည်မုဒ်<ph name="GUEST_LINK_END" /> သုံးနိုင်သည်။ အခြားတစ်ယောက်အတွက် အကောင့်ထည့်လိုပါက သင်၏ <ph name="DEVICE_TYPE" /> တွင် <ph name="LINK_BEGIN" />ပုဂ္ဂိုလ်အသစ်ကို ထည့်နိုင်သည်<ph name="LINK_END" />။

ဝဘ်ဆိုက်နှင့် အက်ပ်များကို ပေးထားသော ခွင့်ပြုချက်များက ဤအကောင့်တွင် အကျုံးဝင်နိုင်သည်။ <ph name="SETTINGS_LINK_BEGIN" />ဆက်တင်များ<ph name="SETTINGS_LINK_END" /> တွင် သင်၏ Google Account များကို စီမံနိုင်သည်။</translation>
<translation id="1640672724030957280">ဒေါင်းလုဒ်လုပ်နေသည်…</translation>
<translation id="2804101107797787361">ပိုလုံခြုံသော WEB3 DNA Browser ဗားရှင်း အသစ် ရနိုင်ပါသည်။</translation>
<translation id="9029405963934901712">ကြော်ငြာပြရန်သုံးသည့် သင်စိတ်ဝင်စားသော ဝဘ်ဆိုက်များ၏ အကြောင်းအရာများကို ကြည့်ကာ ဖယ်ရှားနိုင်သည်။ သင့်လတ်တလော ကြည့်ရှုခြင်းမှတ်တမ်းအပေါ်မူတည်၍ သင့်စိတ်ဝင်စားမှုများကို WEB3 DNA Browser က ခန့်မှန်းသည်။</translation>
<translation id="2051400772676536118">WEB3 DNA Browser ကို နောက်ခံမှာ အလုပ်လုပ်ပါစေ</translation>
<translation id="9219442880476358008">WEB3 DNA Browser ပိုပြီး လုံခြုံစေရန် အတွက်၊ ကျွန်ုပ်တို့သည် <ph name="IDS_EXTENSION_WEB_STORE_TITLE" />ထဲမှာ ဖေါ်ပြမထားသည့်၊ သင် မသိဘဲနှင့် ထည့်ပေးထားတာ ဖြစ်နိုင်သည့်၊ တိုးချဲ့မှု အချို့ကို ပိတ်ထားပါသည်။</translation>
<translation id="2776567154969336836">WEB3 DNA Browser ကို ပြန်လည်တပ်ဆင်ရန်</translation>
<translation id="4915372523140836376">သင်လက်မှတ်ထိုးဝင်ထားသော Google Account များကို စီမံနိုင်သည်။ WEB3 DNA Browser ဘရောင်ဇာ၊ Play Store၊ Gmail စသည်တို့အတွက် သင်၏ Google Account များကို သုံးသည်။ မိသားစုဝင်ကဲ့သို့ တစ်စုံတစ်ယောက်အတွက် အကောင့်ထည့်လိုပါက ၎င်းအစား ထိုပုဂ္ဂိုလ်အသစ်ကို သင့် <ph name="DEVICE_TYPE" /> တွင် ထည့်ပါ။ <ph name="LINK_BEGIN" />ပိုမိုလေ့လာရန်<ph name="LINK_END" /></translation>
<translation id="4370275707492934729">ဝဘ်ဆိုက်များသည် သင်၏စိတ်ဝင်စားမှုများကို WEB3 DNA Browser တွင် သိမ်းနိုင်သည်။ ဥပမာ မာရသွန်အတွက် ရှူးဖိနပ်ဝယ်ရန် ဝဘ်ဆိုက်တွင်ဝင်ကြည့်ပါက ဝဘ်ဆိုက်သည် သင်၏စိတ်ဝင်စားမှုကို မာရသွန်ပြေးခြင်းအဖြစ် သတ်မှတ်နိုင်သည်။ နောင်တွင် ပြိုင်ပွဲအတွက်စာရင်းသွင်းရန် အခြားဝဘ်ဆိုက်သို့ ဝင်ကြည့်သောအခါ ထိုဝဘ်ဆိုက်က သင်၏စိတ်ဝင်စားမှုများပေါ် အခြေခံပြီး အပြေးဖိနပ်ကြော်ငြာကို ပြနိုင်သည်။</translation>
<translation id="4590088122952951314">သင်သည်  စီမံကွပ်ကဲထားသည့် အကောင့် ထဲသို့ လက်မှတ် ထိုးဝင်နေကာ စီမံအုပ်ချုပ်သူအား
 သင့် WEB3 DNA Browser ပရိုဖိုင်ကို ထိန်းချုပ်ခွင့်ကို လွှဲပေးနေသည်။ သင်၏ အက်ပ်များ၊စာညှပ်များ၊ မှတ်တမ်း၊ စကားဝှက်များ၊ နှင့် အခြား ဆက်တင်များလို သင်၏ WEB3 DNA Browser ဒေတာများမှာ <ph name="USER_NAME" /> သို့ ထာဝရ ချိတ်တွဲလျက် ရှိလာကြမည်။ သင်သည်  ဒီဒေတာကို Google အကောင့်များ ဒိုင်ခွက်မှ တစ်ဆင့် ဖျက်လို့ ရနိုင်သော်လည်း၊ သင်သည် ၎င်းဒေတာကို အခြား အကောင့်နှင့် ဆက်စပ်၍ မရနိုင်ပါ။ သင်သည် သင်၏ ရှိနေဆဲ WEB3 DNA Browser ဒေတာကို ထားရှိရန် အတွက် ပရိုဖိုင် အသစ်ကို ပြုလုပ်ရန် ရွေးနိုင်ပါသည်။ ပိုမို လေ့လာရန်။ <ph name="LEARN_MORE" /></translation>
<translation id="1773107071029134155">၎င်းကိုပိတ်ခြင်းဖြင့် WEB3 DNA Browser တွင် လက်မှတ်ထိုးမဝင်ဘဲ Gmail ကဲ့သို့ Google ဝဘ်ဆိုက်များသို့ လက်မှတ်ထိုးဝင်နိုင်ပါသည်</translation>
<translation id="1404683263809963517">WEB3 DNA Browser သည် မတုံ့ပြန်ပါ။ ယခု ပြန်ပြီး ဖွင့်တင်ရမလား?</translation>
<translation id="193439633299369377">အပ်ဒိတ်ပြီးဆုံးရန် ChromiumOS ကို ပြန်စရမည်။</translation>
<translation id="2844934533235602125">ဤအကောင့်ကို တစ်ကြိမ်သာအသုံးပြုလိုပါက WEB3 DNA Browser ဘရောင်ဇာတွင် ‘ဧည့်သည်မုဒ်’ သုံးနိုင်သည်။ အခြားတစ်ယောက်အတွက် အကောင့်ထည့်လိုပါက သင်၏ <ph name="DEVICE_TYPE" /> တွင် <ph name="LINK_BEGIN" />ပုဂ္ဂိုလ်အသစ်ကို ထည့်နိုင်သည်<ph name="LINK_END" />။

ဝဘ်ဆိုက်နှင့် အက်ပ်များကို ပေးထားသော ခွင့်ပြုချက်များက ဤအကောင့်တွင် အကျုံးဝင်နိုင်သည်။ <ph name="SETTINGS_LINK_BEGIN" />ဆက်တင်များ<ph name="SETTINGS_LINK_END" /> တွင် သင်၏ Google Account များကို စီမံနိုင်သည်။</translation>
<translation id="1953553007165777902">ဒေါင်းလုဒ်လုပ်နေသည်… <ph name="MINUTE" /> မိနစ် ကျန်သည်</translation>
<translation id="7100172292317798034">WEB3 DNA Browser သည် မူရင်းဘရောင်ဇာကို ဆုံးဖြတ်ပေးခြင်းသော်လည်းကောင်း သတ်မှတ်ခြင်းသော်လည်းကောင်း ပြုလုပ်၍မရပါ</translation>
<translation id="7388619658790717510">၎င်းသည် ဤစက်ပစ္စည်းမှ အကြောင်းအရာ ၁ ခုကို ဖျက်လိုက်ပါမည်။ သင့်ဒေတာကို နောက်မှ ပြန်ယူရန် WEB3 DNA Browser သို့ <ph name="USER_EMAIL" /> အဖြစ် လက်မှတ်ထိုးဝင်ပါ။</translation>
<translation id="2018879682492276940">ထည့်သွင်းမှု မအောင်မြင်ပါ။ ထပ်စမ်းကြည့်ပါ။</translation>
<translation id="8775681507105719302">သင်၏အခြားစကားဝှက်များတွင် ဒေတာပေါက်ကြားမှုနှင့် အခြားသော လုံခြုံရေးပြဿနာများ ရှိ၊ မရှိ စစ်ဆေးရန် <ph name="BEGIN_LINK" />WEB3 DNA Browser သို့ လက်မှတ်ထိုးဝင်ပါ<ph name="END_LINK" />။</translation>
<translation id="6765354414432698675">Google ဝန်ဆောင်မှုများရှိ ပုဂ္ဂိုလ်ရေးသီးသန့် အတွေ့အကြုံများ ပိုရရှိရန်အတွက် WEB3 DNA Browser မှတ်တမ်းကို ထည့်၊ မထည့် ရွေးနိုင်သည်</translation>
