<!DOCTYPE translationbundle>
<translationbundle lang="ne">
<translation id="1026101648481255140">इन्स्टल गर्ने प्रक्रिया सुचारु गर्नुहोस्</translation>
<translation id="1029669172902658969">&amp;ChromiumOS अपडेट गर्न यसलाई रिलन्च गर्नुहोस्</translation>
<translation id="1065672644894730302">तपाइँका प्राथमिकातहरू पढ्न सकिदैन।

केही सुविधाहरू अनुपलब्ध हुन सक्छन् र प्राथमिकताहरूमा परिवर्तनहरू बचत हुने छैनन्।</translation>
<translation id="4960963727707787489">WEB3 DNA Browser ले तपाईंलाई डेटा चोरीका घटना, हानिकारक एक्स्टेन्सन र थप समस्याहरूबाट सुरक्षित रहन मद्दत गर्न सक्छ</translation>
<translation id="1018420750873862665">WEB3 DNA Browser तपाईंका पासवर्डहरू निर्यात गर्न चाहन्छ। यसो गर्ने अनुमति दिन Windows को आफ्नो पासवर्ड टाइप गर्नुहोस्‌।</translation>
<translation id="8728335547814212082">WEB3 DNA Browser तपाईंको डिफल्ट ब्राउजर हो</translation>
<translation id="3462550327714525487">तपाईंका पासवर्डहरू कतै खुलासा भएका छन् कि छैनन् तथा सुरक्षासम्बन्धी अन्य समस्याबाट सुरक्षित छन् कि छैनन् भन्ने कुरा जाँच्न <ph name="BEGIN_LINK" />WEB3 DNA Browser मा साइन इन गर्नुहोस्<ph name="END_LINK" />।</translation>
<translation id="4464481789599383598">WEB3 DNA Browser का बारेमा</translation>
<translation id="1203500561924088507">इन्स्टल गर्नुभएकोमा धन्यवाद। <ph name="BUNDLE_NAME" /> प्रयोग गर्नुअघि तपाईंले अनिवार्य रूपमा आफ्नो ब्राउजर रिस्टार्ट गर्नु पर्छ।</translation>
<translation id="5978964989109500768">यो सेटिङ अन हुँदा WEB3 DNA Browser ले निष्क्रिय ट्याबहरूले ओगटेको मेमोरी खाली गर्छ। मेमोरी खाली हुँदा सक्रिय ट्याब तथा अन्य एपहरूले कम्प्युटरका अझ बढी स्रोतहरू प्रयोग गर्न सक्छन् र WEB3 DNA Browser पनि अझ छिटो चल्छ। तपाईंले आफ्ना निष्क्रिय ट्याबहरू खोलेपछि ती ट्याबहरू स्वतः सक्रिय हुन्छन्। <ph name="BEGIN_LINK" />थप जान्नुहोस्<ph name="END_LINK" /></translation>
<translation id="2556820941333974881">मेमोरी सेभरले WEB3 DNA Browser लाई अझ छिटो काम गर्ने बनाएको छ</translation>
<translation id="8674698533637405550">WEB3 DNA Browser मा आफ्नो नयाँ प्रोफाइल सेटअप गर्नुहोस्</translation>
<translation id="5897235607289042281">WEB3 DNA Browser मा Google सहायक उपलब्ध छ</translation>
<translation id="4011302926653396528">WEB3 DNA Browser ले पासवर्डहरू देखाउने प्रयास गर्दैछ।</translation>
<translation id="7808556894409107558">तपाइँ WEB3 DNA Browser मा साइन इन</translation>
<translation id="2448956114941459869">तपाईं WEB3 DNA Browser बाट बढीभन्दा बढी फाइदाहरूको आनन्द लिन सक्नुहुन्छ</translation>
<translation id="6123758632973468022">WEB3 DNA Browser को ट्याब सेयर गर्नुहोस्</translation>
<translation id="1232307829393891937">WEB3 DNA Browser लाई तपाईं वरपरको ठाउँको 3D नक्सा बनाउन तपाईंको क्यामेरा प्रयोग गर्ने अनुमति चाहिन्छ</translation>
<translation id="5103307222334991576">{COUNT,plural, =0{तपाईंका व्यवस्थापकका अनुसार तपाईंले यो अद्यावधिक लागू गर्न WEB3 DNA Browser पुनः सुरु गर्नु पर्ने हुन्छ}=1{तपाईंका व्यवस्थापकका अनुसार तपाईंले यो अद्यावधिक लागू गर्न WEB3 DNA Browser पुनः सुरु गर्नु पर्ने हुन्छ। तपाईंको इन्कोग्निटो विन्डो पुनः खुल्ने छैन।}other{तपाईंका व्यवस्थापकका अनुसार तपाईंले यो अद्यावधिक लागू गर्न WEB3 DNA Browser पुनः सुरु गर्नु पर्ने हुन्छ। तपाईंका # वटा इन्कोग्निटो विन्डो पुनः खुल्ने छैनन्।}}</translation>
<translation id="7291131704197390431">WEB3 DNA Browser मा भएका गोपनीयता र सुरक्षासम्बन्धी मुख्य नियन्त्रण सुविधाहरूको समीक्षा गर्नुहोस्</translation>
<translation id="5962221630684419652">तपाईं यो खाता एक पटक मात्र प्रयोग गर्न चाहनुहुन्छ भने तपाईं WEB3 DNA Browser ब्राउजरमार्फत <ph name="GUEST_LINK_BEGIN" />गेस्ट मोड<ph name="GUEST_LINK_END" /> प्रयोग गर्न सक्नुहुन्छ। तपाईं अरू कसैको खाता लिंक गर्न चाहनुहुन्छ भने उहाँलाई <ph name="LINK_BEGIN" />नयाँ व्यक्तिका रूपमा<ph name="LINK_END" /> आफ्नो <ph name="DEVICE_TYPE" /> मा सामेल गराउनुहोस्।

तपाईंले वेबसाइट तथा एपहरूलाई दिइसक्नुभएका अनुमति यो खाताका हकमा पनि लागू हुन सक्छ। तपाईं <ph name="SETTINGS_LINK_BEGIN" />सेटिङ<ph name="SETTINGS_LINK_END" />मा गई आफ्ना Google खाताहरू व्यवस्थापन गर्न सक्नुहुन्छ।</translation>
<translation id="1640672724030957280">डाउनलोड गरिँदै छ...</translation>
<translation id="2804101107797787361">क्रोमियनको नयाँ, सुरक्षित संस्करण उपलब्ध छ।</translation>
<translation id="9029405963934901712">तपाईं वेबसाइटहरूले तपाईंलाई विज्ञापन देखाउन प्रयोग गर्ने रुचिका विषयहरू हेर्न तथा हटाउन सक्नुहुन्छ। WEB3 DNA Browser ले तपाईंको हालसालैको ब्राउजिङ इतिहासका आधारमा तपाईंलाई रुचि लाग्न सक्ने विषयहरू पत्ता लगाउँछ।</translation>
<translation id="2051400772676536118">क्रोमियम पृष्ठभूमिमा चलाउछन्</translation>
<translation id="9219442880476358008">WEB3 DNA Browser लाई अझ सुरक्षित बनाउनको लागि, हामीले <ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> मा सूचीकृत नगरिएका केही एक्स्टेन्सनहरूलाई अक्षम बनाएका छौँ र तपाईंलाई थाहा दिए बिना थपिएको हुन सक्छ।</translation>
<translation id="2776567154969336836">WEB3 DNA Browser पुनर्स्थापित गर्नुहोस्</translation>
<translation id="4915372523140836376">तपाईं साइन इन गरिएका आफ्ना Google खाताहरू व्यवस्थापन गर्न सक्नुहुन्छ। तपाईंका Google खाताहरू WEB3 DNA Browser ब्राउजर, Play स्टोर, Gmail र अन्य एपहरूमा प्रयोग गरिन्छन्। तपाईं परिवारका सदस्य जस्ता अरू कसैको खाता थप्न चाहनुहुन्छ भने उहाँको खाता थप्नुको साटो उहाँलाई नयाँ व्यक्तिका रूपमा आफ्नो <ph name="DEVICE_TYPE" /> मा सामेल गराउनुहोस्। <ph name="LINK_BEGIN" />थप जान्नुहोस्<ph name="LINK_END" /></translation>
<translation id="4370275707492934729">साइटहरूले WEB3 DNA Browser मा तपाईंका रुचिसम्बन्धी जानकारी भण्डारण गर्न सक्छन्। उदाहरणका लागि, तपाईंले कुनै साइटमा गएर म्याराथनमा दौडिँदा लगाइने जुत्ता किन्नुभयो भने उक्त साइटले तपाईं म्याराथन दौडमा रुचि राख्नुहुन्छ भन्ने कुरा बुझ्न सक्छ। पछि तपाईं दौड प्रतियोगितामा आफ्नो नाम लेखाउन अर्कै साइटमा जानुभयो भने उक्त साइटले तपाईंको रुचिका आधारमा तपाईंलाई दौडिँदा लगाइने जुत्ताको विज्ञापन देखाउन सक्छ।</translation>
<translation id="4590088122952951314">तपाईंले व्यवस्थित खातासँगै साइन इन गरि यसको व्यवस्थापकलाई तपाईंको क्रोमियम प्रोफाइल माथि नियन्त्रण दिइरहनुभएको छ। तपाईंको क्रोमियम डाटा, जस्तै तपाईंका एप्स, बुकमार्कहरू, इतिहास, पासवर्डहरू, र अन्य सेटिङहरू <ph name="USER_NAME" /> मा स्थायी रूपमा बाँधिनेछन्। तपाईं यस डाटालाई गूगल खाता ड्यासबोर्ड मार्फत मेटाउन सक्षम हुनुहुनेछ, तर तपाईं यस खातालाई अर्को खातामा संलग्न गर्न सक्षम हुनुहुनेछैन। तपाईंले आफ्नो विद्यमान क्रोमियम डाटालाई अलग राख्न वैकल्पिक रूपमा नयाँ प्रोफाइल सिर्जना गर्न सक्नुहुन्छ। <ph name="LEARN_MORE" /></translation>
<translation id="1773107071029134155">यसलाई निष्क्रिय पारेर, तपाईं WEB3 DNA Browser मा साइन इन नगरिकनै Gmail जस्ता Google का साइटहरूमा साइन इन गर्न सक्नुहुन्छ</translation>
<translation id="1404683263809963517">WEB3 DNA Browser ले कुनै प्रतिक्रिया जनाइरहेको छैन। अहिले नै पुन: लन्च गर्ने?</translation>
<translation id="193439633299369377">यो अपडेट लागू गर्न ChromiumOS रिस्टार्ट गर्नु पर्ने हुन्छ।</translation>
<translation id="2844934533235602125">तपाईं यो खाता एक पटक मात्र प्रयोग गर्न चाहनुहुन्छ भने तपाईं WEB3 DNA Browser ब्राउजरमार्फत गेस्ट मोड प्रयोग गर्न सक्नुहुन्छ। तपाईं अरू कसैको खाता लिंक गर्न चाहनुहुन्छ भने उहाँलाई <ph name="LINK_BEGIN" />नयाँ व्यक्तिका रूपमा<ph name="LINK_END" /> आफ्नो <ph name="DEVICE_TYPE" /> मा सामेल गराउनुहोस्।

तपाईंले वेबसाइट तथा एपहरूलाई दिइसक्नुभएका अनुमति यो खाताका हकमा पनि लागू हुन सक्छ। तपाईं <ph name="SETTINGS_LINK_BEGIN" />सेटिङ<ph name="SETTINGS_LINK_END" />मा गई आफ्ना Google खाताहरू व्यवस्थापन गर्न सक्नुहुन्छ।</translation>
<translation id="1953553007165777902">डाउनलोड गरिँदै छ... <ph name="MINUTE" /> मिनेट बाँकी छ</translation>
<translation id="7100172292317798034">WEB3 DNA Browser ले डिफल्ट ब्राउजर निर्धारण वा सेट गर्न सक्दैन</translation>
<translation id="7388619658790717510">यसले यो डिभाइसको १ वस्तु मेट्नेछ। पछि आफ्नो डेटा प्राप्त गर्न WEB3 DNA Browser मा <ph name="USER_EMAIL" /> को रूपमा साइन इन गर्नुहोस्।</translation>
<translation id="2018879682492276940">इन्स्टल गर्न सकिएन। कृपया फेरि प्रयास गर्नुहोस्।</translation>
<translation id="8775681507105719302">तपाईंका अन्य पासवर्डहरू कतै खुलासा भएका छन् कि छैनन् तथा सुरक्षासम्बन्धी अन्य समस्याबाट सुरक्षित छन् कि छैनन् भन्ने कुरा जाँच्न <ph name="BEGIN_LINK" />WEB3 DNA Browser मा साइन इन गर्नुहोस्<ph name="END_LINK" />।</translation>
<translation id="6765354414432698675">Google का सेवाहरूमा आफ्नो आवश्यकताअनुसारका सुविधाहरू पाउन WEB3 DNA Browser को ब्राउजिङ इतिहास समावेश गर्ने कि नगर्ने भन्ने कुरा छनौट गर्नुहोस्</translation>
<translation id="5773286839920477494">WEB3 DNA Browser ले आफ्ना मूल प्रमाणपत्र कसरी व्यवस्थापन गर्छ भन्ने कुरासम्बन्धी जानकारी</translation>
<translation id="1342703999636762729">WEB3 DNA Browser आफूले चाहे जस्तो बनाउनुहोस्</translation>
<translation id="2174917724755363426">इन्स्टल गर्ने प्रक्रिया पूरा भएन। तपाईंले यो प्रक्रिया रद्द गर्न खोज्नुभएकै हो?</translation>
<translation id="4604256298037443917">WEB3 DNA Browser - नेटवर्क साइन इन - <ph name="PAGE_TITLE" /></translation>
<translation id="3692764894142598026">यदि तपाईँले कम्प्युटरलाई साझा गर्नुभयो भने, साथी तथा परिवारले अलग रूपमा ब्राउज गर्न सक्छन् र तिनीहरूले चाहे अनुरूपको क्रोमियम सेटअप गर्न सक्छन्।</translation>
<translation id="1653667178840181002">WEB3 DNA Browser मा भण्डारण गरिएका असुरक्षित साइटको सूची जाँच गरी URL हरू सुरक्षित छन् कि छैनन् भन्ने कुरा यकिन गर्छ। कुनै साइटले तपाईंको पासवर्ड चोरी गर्न खोज्दा वा तपाईंले कुनै हानिकारक फाइल डाउनलोड गर्दा WEB3 DNA Browser ले पेजमा भएका केही सामग्रीसहित उक्त साइटका URL हरू Safe Browsing मा पठाउन पनि सक्छ।</translation>
<translation id="4170954887813547201">यहाँबाट आफ्नो Android फोनमा कुनै नम्बर पठाउन दुवै यन्त्रमा WEB3 DNA Browser मा साइन इन गर्नुहोस्।</translation>
<translation id="7632546848754920458">यो विस्तारले तपाईँले WEB3 DNA Browser सुरु गर्दा देखाइएको पृष्ठलाई परिवर्तन गरेको छ।</translation>
<translation id="2359808026110333948">जारी राख्नुहोस्</translation>
<translation id="2384373936468275798">तपाईंको खाताको साइन इनसम्बन्धी विवरणको म्याद सकिएको हुनाले ChromiumOS ले तपाईंको डेटा सिंक गर्न सकेन।</translation>
<translation id="3766979587851503326">विस्तार "<ph name="EXTENSION_NAME" />" ले तपाईँले WEB3 DNA Browser सुरु गर्दा देखाइएको पृष्ठलाई परिवर्तन गरेको छ।</translation>
<translation id="3197411627422504716">यो साइट चलाउन WEB3 DNA Browser लाई क्यामेरा तथा माइक्रोफोन प्रयोग गर्ने अनुमति दिनु पर्ने हुन्छ</translation>
<translation id="6895208784707407784">WEB3 DNA Browser मा</translation>
<translation id="2485422356828889247">विस्थापन गर्नुहोस्</translation>
<translation id="5049950391929594900">WEB3 DNA Browser लाई फाइलहरू डाउनलोड गर्न भण्डारणमाथिको पहुँच आवश्यक पर्छ</translation>
<translation id="2749516262341915024">WEB3 DNA Browser सहायक</translation>
<translation id="2113242903075215938">कार्य प्रोफाइलका एड्मिन यो प्रोफाइल चलाउँदा WEB3 DNA Browser मा सिर्जना हुने (बुकमार्क, इतिहास, पासवर्ड र अन्य सेटिङलगायतका) सबै डेटा हटाउन सक्नुहुन्छ। <ph name="LEARN_MORE" /></translation>
<translation id="4952960270884842265">WEB3 DNA Browser प्रयोग गरिराख्नुहोस्</translation>
<translation id="2731252252225464533">स्थापना अवधिमा अपरेटिङ सिस्टम त्रुटि भयो। कृपया पुन: क्रोमियम डाउनलोड गर्नुहोस्।</translation>
