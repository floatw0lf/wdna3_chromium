<translation id="65082721690930806">WEB3 DNA Browser का लागि महान एपहरू, खेलहरू, विस्तारहरू र विषयवस्तुहरू पत्ता लगाउनुहोस्।</translation>
<translation id="8180918330054927789">WEB3 DNA Browser UI प्रदर्शन गर्न यो भाषाको प्रयोग गरिन्छ</translation>
<translation id="4222932583846282852">रद्द गरिँदै...</translation>
<translation id="4117615645977273587">तपाइँको WEB3 DNA Browser लगत यस खातामा लिङ्क गर्ने?</translation>
<translation id="2562528065031024752">WEB3 DNA Browser को सम्बन्धमा मद्दत प्राप्त गर्नुहोस्</translation>
<translation id="4628286205171331451">अनिश्चित त्रुटिको कारणले गर्दा स्थापना असफल भयो। यदि WEB3 DNA Browser हालै चालू छ भने, कृपया त्यसलाई बन्द गर्नुहोस् र पुन: प्रयास गर्नुहोस्।</translation>
<translation id="4304713468139749426">पासवर्ड म्यानेजर</translation>
<translation id="4334294535648607276">डाउनलोड सम्पन्न भयो</translation>
<translation id="439358628917130594"><ph name="MANAGER" /> को नीतिअनुसार तपाईंले यो डिभाइस प्रयोग गर्नुअघि सेवाका निम्न सर्तहरू पढेर स्वीकार गर्नु पर्ने हुन्छ। यी सर्तले ChromiumOS का सर्तहरू विस्तार, परिमार्जन वा सीमित गर्दैनन्।</translation>
<translation id="5363800095683563940">जे भए पनि WEB3 DNA Browser बाट बाहिरिने हो?</translation>
<translation id="4413681411297396618">WEB3 DNA Browser लाई पृष्ठभूमिमा चल्न दिनुहोस्</translation>
<translation id="4960563596527056032">WEB3 DNA Browser आफू अनुकूल र नियन्त्रण गर्नुहोस्</translation>
<translation id="4427306783828095590">परिष्कृत सुरक्षा प्रयोग गरी फिसिङ तथा मालवेयरमाथि अझ राम्रोसँग रोक लगाउन सकिन्छ</translation>
<translation id="5075487038316202932">WEB3 DNA Browser मा तपाईंलाई स्वागत छ; ब्राउजरको नयाँ विन्डो खोलियो</translation>
<translation id="8333408299151688471">WEB3 DNA Browser अद्यावधिक भएन, केही चिज गडबड भयो। <ph name="BEGIN_LINK" />WEB3 DNA Browser अद्यावधिक गर्दा देखिएका समस्या तथा अद्यावधिक नहुने समस्याहरू समाधान गर्नुहोस्।<ph name="END_LINK" /></translation>
<translation id="5710517655208362990">नयाँ WEB3 DNA Browser प्रोफाइल प्रयोग गरी साइन इन गर्ने हो?</translation>
<translation id="4567424176335768812">तपाइँ <ph name="USER_EMAIL_ADDRESS" /> को रूपमा साइन इन हुनुभएको छ। अब तपाइँले तपाइँका सबै साइन इन भएका यन्त्रहरूमा तपाइँका पृष्ठमञ्जूषाहरू, इतिहास, र अन्य सेटिङहरू पहुँच गर्न सक्नुहुन्छ।</translation>
<translation id="4594305310729380060">यो डिभाइसको पासवर्ड म्यानेजरमा</translation>
<translation id="8700214093481776621">क्रोमियम एप्स</translation>
<translation id="4613863813562375431">ChromiumOS को संस्करण</translation>
<translation id="6951246183774166202">लगभग अद्यावधिक भयो! अद्यावधिक गर्ने कार्य सम्पन्न गर्न WEB3 DNA Browser लाई पुनः सुरु गर्नुहोस्।</translation>
<translation id="1967316171334904609">चेतावनी: WEB3 DNA Browser ले एक्स्टेन्सनहरूलाई तपाईंको ब्राउजिङ इतिहास रेकर्ड गर्नबाट रोक्न सक्दैन। यो एक्स्टेन्सन इन्कोग्निटो मोडमा अफ गर्न यो विकल्पको चयन रद्द गर्नुहोस्।</translation>
<translation id="6242940079717718930">तपाईंले WEB3 DNA Browser को प्रयोगसम्बन्धी रिपोर्टहरू पनि सेयर गर्नुभयो भने ती रिपोर्टमा तपाईंले खोलेका URL हरू समावेश हुन्छन्</translation>
<translation id="4405105480942922067">यो प्रोफाइल अर्को WEB3 DNA Browser प्रक्रिया (<ph name="PROCESS_ID" />) द्वारा अर्को कम्प्युटर (<ph name="HOST_NAME" />) मा प्रयोग गरिएको देखिएको छ। WEB3 DNA Browser ले प्रोफाइल लक गरेको छ जसले गर्दा त्यो दूषित हुँदैन। यदि तपाइँ यस प्रोफाइललाई अन्य कुनै प्रक्रियाहरूले प्रयोग गरिरहेको छैन भनेर निश्चय हुनुहुन्छ भमे, तपाइँले प्रोफाइल अनलक गर्न र WEB3 DNA Browser फेरि सुरु गर्न सक्नुहुन्छ।</translation>
<translation id="4680828127924988555">इन्स्टल गर्ने प्रक्रिया रद्द गर्नुहोस्</translation>
<translation id="3750760070906465924">कुनै व्यक्तिले अघिल्लो पटक यस कम्प्युटरमा <ph name="ACCOUNT_EMAIL_LAST" /> को रूपमा WEB3 DNA Browser मा साइन इन गरेको थियो। कृपया आफ्नो जानकारी छुट्टै राख्न WEB3 DNA Browser मा एउटा नयाँ प्रयोगकर्ता सिर्जना गर्नुहोस्।</translation>
<translation id="1217313267986183942">जे भए पनि WEB3 DNA Browser छाडेर बाहिरिने हो?</translation>
<translation id="4805555266423130696">WEB3 DNA Browser को एक विशेष सुरक्षा अद्यावधिक भर्खरै लागू गरियो। पुनः सुरु गर्नुहोस् र हामी तपाईंका ट्याबहरू पुनर्स्थापना गर्ने छाैँ।</translation>
<translation id="3541589509773411057">तपाईं जुनसुकै बेला WEB3 DNA Browser का सेटिङमा गई आफ्नो सहमति फिर्ता लिन सक्नुहुन्छ। यी ट्रायलहरूमा विज्ञापन देखाउने हालको तरिका नै अपनाइने भएकाले तपाईंले गर्नुभएका परिवर्तनहरू तुरुन्तै लागू हुँदैनन्।</translation>
<translation id="2655572098566031184">WEB3 DNA Browser तपाईंका पासवर्डहरू जाँच्न सक्दैन। २४ घन्टापछि फेरि प्रयास गर्नुहोस् वा <ph name="BEGIN_LINK" />आफ्नो Google खातामा गई आफ्ना पासवर्डहरू जाँच्नुहोस्<ph name="END_LINK" />।</translation>
<translation id="479167709087336770">यसले Google खोजमा प्रयोग गरिएकै स्पेल चेकर प्रयोग गर्दछ। तपाईंले ब्राउजरमा टाइप गर्ने पाठ Google मा पठाइन्छ। तपाईं सेटिङमा गई जुनसुकै बेला उक्त व्यवहार परिवर्तन गर्न सक्नुहुन्छ।</translation>
<translation id="6402416911698425675">mDNS ट्राफिक अनुमति दिन WEB3 DNA Browser को लागि इन्बाउन्ड नियम।</translation>
<translation id="5496148131599227635">&amp;WEB3 DNA Browser अपडेट गर्न पुनः सुरु गर्नुहोस्</translation>
<translation id="3889712706226772861">WEB3 DNA Browser पृष्ठभूमि मोडमा छ।</translation>
<translation id="5502939625951695202">अतिथिहरूले कुनैपनि कुरालाई पछाडि छोडे बिना WEB3 DNA Browser प्रयोग गर्न सक्छन्।</translation>
<translation id="4935574428555172200">तपाइँ अफैलाई WEB3 DNA Browser मा थप्नुहोस्</translation>
<translation id="60503244591890876">WEB3 DNA Browser ले साइटहरूलाई कम जानकारी प्रयोग गरेर उही स्तरको ब्राउजिङ अनुभव प्रदान गर्न सघाउने नयाँ सुविधाहरूको परीक्षण गरिरहेको छ</translation>
<translation id="282690038359289128">कुनै पनि पासवर्ड सुरक्षित गरिएको छैन। तपाईंले आफ्ना पासवर्डहरू सुरक्षित गर्नुभएको छ भने मात्र WEB3 DNA Browser ले तिनको जाँच गर्न सक्छ।</translation>
<translation id="3588920839125338516"><ph name="EXISTING_USER" /> अहिले यो WEB3 DNA Browser प्रोफाइलमा साइन इन हुनुहुन्छ। तपाईंले यसो गर्नुभयो भने <ph name="USER_EMAIL_ADDRESS" /> का लागि नयाँ WEB3 DNA Browser प्रोफाइल बनाइने छ</translation>
<translation id="1712448899328197828">आफूले गरेका परिवर्तनहरू लागू गर्न WEB3 DNA Browser पुनः सुरु गर्नुहोस्</translation>
<translation id="5425968257754155673">ट्रायल सुविधाहरू अन छन् र WEB3 DNA Browser ले तपाईंलाई अनियमित रूपमा एक्टिभ ट्रायलअन्तर्गत राखेको छ भने तपाईंको ब्राउजिङ इतिहासका कारण तपाईंलाई देखाइने विज्ञापन र तलका अनुमानित रुचिहरू फरक पर्न सक्छन्। तपाईंको गोपनीयताको सुरक्षार्थ WEB3 DNA Browser ले हरेक महिना क्रमिक रूपमा तपाईंका रुचिहरू मेटाउँछ।</translation>
<translation id="4715135477147720071">तपाइँ एक व्यवस्थापित खाताको साथमा साइनइन गर्दै हुनुहुन्छ र त्यसको प्रशासकलाई तपाइँको WEB3 DNA Browser प्रोफाइलमा नियन्त्रण दिँदै हुनुहुन्छ। तपाइँको WEB3 DNA Browser लगत, जस्तै की तपाइँका एपहरू, पृष्ठमञ्जूषाहरू, इतिहास, पासवर्डहरू, र अन्य सेटिङहरू स्थायी रूपमा <ph name="USER_NAME" /> मा बाँधिनेछ। तपाइँले यस लगतलाई Google खााता ड्यासबोर्ड मार्पत हटाउन सक्नुहुनेछ, तर तपाइँले यस लगतलाई अर्को खातासँग सम्बन्ध गर्न सक्नुहुनेछैन। <ph name="LEARN_MORE" /></translation>
<translation id="3959775081883542439">WEB3 DNA Browser लाई अद्यावधिक गर्दै (<ph name="PROGRESS_PERCENT" />)</translation>
<translation id="8468846229743402892">WEB3 DNA Browser मा साइन इन गर्ने अनुमति दिनुहोस्</translation>
<translation id="868709743621506099">क्रोमियमको नयाँ संस्करण उपलब्ध छ ।</translation>
<translation id="8954902894032987165">क्रोमियमबाट हटाउनुहोस्</translation>
<translation id="8529594966625997901">{0,plural, =0{WEB3 DNA Browser अब बन्द हुने छ।}=1{WEB3 DNA Browser १ सेकेन्डपछि बन्द हुने छ।}other{WEB3 DNA Browser # सेकेन्डपछि बन्द हुने छ।}}</translation>
<translation id="2581842036863502750">WEB3 DNA Browser लाई तपाइँको डिफल्ट ब्राउजरको रूपमा सेट गर्नुहोस्</translation>
<translation id="2775837035201231287"><ph name="PAGE_TITLE" /> - WEB3 DNA Browser बिटा</translation>
<translation id="3342188394733679831">WEB3 DNA Browser मा अब उप्रान्त Linux को यो संस्करण प्रयोग गर्न नमिल्ने भएकाले WEB3 DNA Browser ले राम्ररी काम नगर्न सक्छ</translation>
<translation id="6744035239102820989">WEB3 DNA Browser लाई यो साइटसँग तपाईंको स्थान आदान प्रदान गर्न तपाईंको स्थानमाथिको पहुँच आवश्यक पर्छ</translation>
<translation id="1336779017674457494">तपाईंको गोपनीयताको सुरक्षार्थ हामी ४ हप्ताभन्दा पुराना तपाईंका रुचिहरू स्वतः मेटाउँछौँ। तपाईंले विभिन्न साइटहरू ब्राउज गरिराख्ने क्रममा कुनै रुचि यो सूचीमा फेरि देखिन सक्छ। र WEB3 DNA Browser ले तपाईंको रुचि राम्रोसँग ठम्याउन सकेन वा तपाईं खास विज्ञापनहरू हेर्न चाहनुहुन्न भने तपाईं उक्त रुचि हटाउन सक्नुहुन्छ।</translation>
<translation id="5998903067774658363">WEB3 DNA Browser ले नवीनतम सिस्टम अपडेट स्थापित गर्दै गर्दा प्रतिक्षा गर्नुहोस्।</translation>
<translation id="840929360644660930">WEB3 DNA Browser ले पासवर्डहरू बदल्ने प्रयास गरिरहेको छ। यसो गर्ने अनुमति दिन Windows को आफ्नो पासवर्ड टाइप गर्नुहोस्।</translation>
