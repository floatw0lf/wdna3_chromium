<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="bn">
<translation id="1026101648481255140">ইনস্টলেশন আবার চালু করুন</translation>
<translation id="1029669172902658969">&amp;ChromiumOS আপডেট করতে আবার লঞ্চ করুন</translation>
<translation id="1065672644894730302">আপনার অভিরুচিগুলি পড়া যাবে না৷ কিছু বৈশিষ্ট্য অনুপলব্ধ থাকতে পারে ও অভিরুচিগুলিতে করা পরিবর্তনগুলি সংরক্ষিত হবে না৷</translation>
<translation id="4960963727707787489">ডেটার নিরাপত্তা লঙ্ঘন, এক্সটেনশন এবং আরও অনেক কিছুর থেকে WEB3 DNA Browser আপনাকে সুরক্ষিত রাখতে সাহায্য করে</translation>
<translation id="1018420750873862665">WEB3 DNA Browser আপনার পাসওয়ার্ড এক্সপোর্ট করতে চাইছে। অনুমতি দিতে Windows এর পাসওয়ার্ড টাইপ করুন।</translation>
<translation id="8728335547814212082">WEB3 DNA Browser আপনার ডিফল্ট ব্রাউজার</translation>
<translation id="3462550327714525487">আপনার পাসওয়ার্ড ডেটার নিরাপত্তা লঙ্ঘন এবং অন্যান্য নিরাপত্তা সংক্রান্ত সমস্যা থেকে সুরক্ষিত কিনা তা চেক করতে <ph name="BEGIN_LINK" />WEB3 DNA Browser-এ সাইন-ইন করুন<ph name="END_LINK" />।</translation>
<translation id="4464481789599383598">WEB3 DNA Browser সম্পর্কে</translation>
<translation id="1203500561924088507">ইনস্টল করার জন্য ধন্যবাদ। <ph name="BUNDLE_NAME" /> ব্যবহার করার আগে আপনাকে অবশ্যই ব্রাউজার রিস্টার্ট করতে হবে।</translation>
<translation id="5978964989109500768">চালু থাকাকালীন, WEB3 DNA Browser ইনঅ্যাক্টিভ ট্যাব থেকে মেমরি খালি করে। এটি অ্যাক্টিভ ট্যাব এবং অন্যান্য অ্যাপ্লিকেশনের জন্য আরও কম্পিউটার রিসোর্স প্রদান করে এবং WEB3 DNA Browser-এর স্পিড বেশি রাখে। আপনার ইনঅ্যাক্টিভ ট্যাবগুলি আবার ব্যবহার করা শুরু করলে অটোমেটিক সেগুলি অ্যাক্টিভ হয়ে যাবে। <ph name="BEGIN_LINK" />আরও জানুন<ph name="END_LINK" /></translation>
<translation id="2556820941333974881">'মেমরি সেভার' ফিচার WEB3 DNA Browser-কে আরও দ্রুত করে তুলেছে</translation>
<translation id="8674698533637405550">আপনার নতুন WEB3 DNA Browser প্রোফাইল সেট আপ করুন</translation>
<translation id="5897235607289042281">WEB3 DNA Browser-এ Google Assistant</translation>
<translation id="4011302926653396528">WEB3 DNA Browser পাসওয়ার্ডগুলি দেখানোর চেষ্টা করছে৷</translation>
<translation id="7808556894409107558">আপনি WEB3 DNA Browser এ প্রবেশ করেছেন!</translation>
<translation id="2448956114941459869">WEB3 DNA Browser থেকে সবচেয়ে বেশি সুবিধা পেতে পারেন</translation>
<translation id="6123758632973468022">একটি WEB3 DNA Browser ট্যাব শেয়ার করুন</translation>
<translation id="1232307829393891937">আপনার আশেপাশের 3D ম্যাপ তৈরি করতে এই সাইটটির জন্য WEB3 DNA Browser-কে আপনার ক্যামেরা অ্যাক্সেস করার অনুমতি দিতে হবে</translation>
<translation id="5103307222334991576">{COUNT,plural, =0{একটি আপডেট প্রয়োগ করতে আপনার অ্যাডমিনিস্ট্রেটর আপনাকে WEB3 DNA Browser আবার চালু করতে বলছেন}=1{একটি আপডেট প্রয়োগ করতে আপনার অ্যাডমিনিস্ট্রেটর আপনাকে WEB3 DNA Browser আবার চালু করতে বলছেন। আপনার ছদ্মবেশী উইন্ডো আবার খুলবে না।}one{একটি আপডেট প্রয়োগ করতে আপনার অ্যাডমিনিস্ট্রেটর আপনাকে WEB3 DNA Browser আবার চালু করতে বলছেন। আপনার #টি ছদ্মবেশী উইন্ডো আবার খুলবে না।}other{একটি আপডেট প্রয়োগ করতে আপনার অ্যাডমিনিস্ট্রেটর আপনাকে WEB3 DNA Browser আবার চালু করতে বলছেন। আপনার #টি ছদ্মবেশী উইন্ডো আবার খুলবে না।}}</translation>
<translation id="7291131704197390431">WEB3 DNA Browser-এ মূল গোপনীয়তা এবং নিরাপত্তা নিয়ন্ত্রণ পর্যালোচনা করুন</translation>
<translation id="5962221630684419652">শুধু একবারের জন্য এই অ্যাকাউন্ট ব্যবহার করলে, আপনি WEB3 DNA Browser ব্রাউজার থেকে <ph name="GUEST_LINK_BEGIN" />গেস্ট মোড<ph name="GUEST_LINK_END" /> ব্যবহার করতে পারবেন। অন্য কোনও ব্যক্তির জন্য অ্যাকাউন্ট যোগ করতে চাইলে, <ph name="DEVICE_TYPE" />-এ <ph name="LINK_BEGIN" />নতুন ব্যক্তিকে যোগ করুন<ph name="LINK_END" />।

বিভিন্ন ওয়েবসাইট ও অ্যাপকে আপনার আগে দেওয়া অনুমতি এই অ্যাকাউন্টের ক্ষেত্রেও প্রযোজ্য হবে। <ph name="SETTINGS_LINK_BEGIN" />সেটিংস<ph name="SETTINGS_LINK_END" /> থেকে আপনার Google অ্যাকাউন্ট ম্যানেজ করতে পারবেন।</translation>
<translation id="1640672724030957280">ডাউনলোড হচ্ছে...</translation>
<translation id="2804101107797787361">WEB3 DNA Browser-এর একটি নতুন, নিরাপদ ভার্সন উপলভ্য আছে৷</translation>
<translation id="9029405963934901712">আগ্রহের যেসব বিষয়ের উপর ভিত্তি করে সাইট আপনাকে বিজ্ঞাপন দেখায়, আপনি সেগুলি দেখতে ও সরিয়ে দিতে পারবেন। WEB3 DNA Browser আপনার সাম্প্রতিক ব্রাউজিং ইতিহাসের উপর ভিত্তি করে আপনার আগ্রহ সম্পর্কে ধারণা করতে পারে।</translation>
<translation id="2051400772676536118">WEB3 DNA Browser-কে ব্যাকগ্রাউন্ডে চলতে দিন</translation>
<translation id="9219442880476358008">WEB3 DNA Browser কে আরও নিরাপদ করতে, আমরা কিছু এক্সটেনশান অক্ষম করেছি যা <ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> এ তালিকাবদ্ধ করা হয়নি এবং হয়ত আপনাকে না জানিয়ে যোগ করা হয়েছে৷</translation>
<translation id="2776567154969336836">WEB3 DNA Browser আবার ইন্সটল করুন</translation>
<translation id="4915372523140836376">আপনার সাইন-ইন করা Google অ্যাকাউন্ট ম্যানেজ করতে পারবেন। WEB3 DNA Browser ব্রাউজার, Play Store, Gmail সহ আরও অনেক কিছুর জন্য আপনার Google অ্যাকাউন্ট ব্যবহার করা হয়। পরিবারের সদস্যের মতো অন্য কারও অ্যাকাউন্ট যোগ করতে চাইলে, তার পরিবর্তে আপনার <ph name="DEVICE_TYPE" />-এ নতুন ব্যক্তিকে যোগ করুন। <ph name="LINK_BEGIN" />আরও জানুন<ph name="LINK_END" /></translation>
<translation id="4370275707492934729">WEB3 DNA Browser-এর মাধ্যমে আপনার আগ্রহের বিষয়ে তথ্যগুলি সাইট স্টোর করতে পারে। যেমন, আপনি যদি ম্যারাথনের জন্য জুতো কেনার একটি সাইট ভিজিট করেন, তাহলে সাইটটি আপনার আগ্রহকে ম্যারাথন দৌড় হিসেবে বিবেচনা করবে। পরে আপনি যদি রেসের জন্য রেজিস্ট্রেশন করতে অন্য একটি সাইটে যান, তাহলে আপনার আগ্রহের উপর ভিত্তি করে সাইটটি আপনাকে দৌড়ানোর জুতোর বিজ্ঞাপন দেখাবে।</translation>
<translation id="4590088122952951314">আপনি একটি পরিচালিত অ্যাকাউন্টের মাধ্যমে সাইন-ইন করুন করছেন এবং এর অ্যাডমিনিস্ট্রেটরকে আপনার WEB3 DNA Browser প্রোফাইলের উপরে নিয়ন্ত্রণ দিচ্ছেন৷ আপনার WEB3 DNA Browser ডেটা, যেমন অ্যাপ, বুকমার্ক, ইতিহাস, পাসওয়ার্ড এবং অন্যান্য সেটিংস <ph name="USER_NAME" /> এতে স্থায়ীভাবে সম্পৃক্ত হবে৷ আপনি Google অ্যাকাউন্টগুলির ড্যাশবোর্ডের মাধ্যমে এই ডেটাগুলি মুছতে চালু হবেন, কিন্তু অন্য অ্যাকাউন্টের সাথে এই ডেটা সংশ্লিষ্ট করতে পারবেন না৷ বিকল্প হিসেবে আপনি আপনার বিদ্যমান WEB3 DNA Browser তথ্য আলাদা রাখার জন্য একটি নতুন প্রোফাইল তৈরি করতে পারেন৷ <ph name="LEARN_MORE" /></translation>
<translation id="1773107071029134155">এটি বন্ধ করার মানে হল, আপনি WEB3 DNA Browser-এ সাইন-ইন না করে Gmail এর মতো Google সাইটগুলিতে সাইন-ইন করতে পারেন</translation>
<translation id="1404683263809963517">WEB3 DNA Browser সাড়া দিচ্ছে না৷ আবার শুরু করবেন?</translation>
<translation id="193439633299369377">আপডেটটি প্রয়োগ করতে ChromiumOS আবার চালু করা প্রয়োজন।</translation>
<translation id="2844934533235602125">শুধু একবারের জন্য এই অ্যাকাউন্ট ব্যবহার করলে, আপনি WEB3 DNA Browser ব্রাউজার থেকে 'গেস্ট মোড' ব্যবহার করতে পারবেন। অন্য কোনও ব্যক্তির জন্য অ্যাকাউন্ট যোগ করতে চাইলে, <ph name="DEVICE_TYPE" />-এ <ph name="LINK_BEGIN" />নতুন ব্যক্তিকে যোগ করুন<ph name="LINK_END" />।

বিভিন্ন ওয়েবসাইট ও অ্যাপকে আপনার আগে দেওয়া অনুমতি এই অ্যাকাউন্টের ক্ষেত্রেও প্রযোজ্য হবে। <ph name="SETTINGS_LINK_BEGIN" />সেটিংস<ph name="SETTINGS_LINK_END" /> থেকে আপনার Google অ্যাকাউন্ট ম্যানেজ করতে পারবেন।</translation>
<translation id="1953553007165777902">ডাউনলোড হচ্ছে... <ph name="MINUTE" /> মিনিট বাকি আছে</translation>
<translation id="7100172292317798034">WEB3 DNA Browser ডিফল্ট ব্রাউজার নির্ধারণ বা সেট করতে পারছে না</translation>
<translation id="7388619658790717510">এটি এই ডিভাইস থেকে ১টি আইটেম মুছে দেবে। আপনার ডেটা পরে পুনরুদ্ধার করার জন্য, WEB3 DNA Browser-এ <ph name="USER_EMAIL" /> হিসেবে সাইন-ইন করুন।</translation>
<translation id="2018879682492276940">ইনস্টল করা যায়নি। আবার চেষ্টা করুন।</translation>
<translation id="8775681507105719302">আপনার অন্যান্য পাসওয়ার্ড ডেটার নিরাপত্তা লঙ্ঘন এবং অন্যান্য নিরাপত্তা সংক্রান্ত সমস্যা থেকে সুরক্ষিত কিনা তা চেক করতে <ph name="BEGIN_LINK" />WEB3 DNA Browser-এ সাইন-ইন করুন<ph name="END_LINK" />।</translation>
<translation id="6765354414432698675">Google পরিষেবাতে আরও পছন্দমতো অভিজ্ঞতার জন্য WEB3 DNA Browser ইতিহাস অন্তর্ভুক্ত করবেন কিনা তা বেছে নিন</translation>
<translation id="5773286839920477494">WEB3 DNA Browser কীভাবে মূল সার্টিফিকেট ম্যানেজ করে সেই বিষয়ে তথ্য</translation>
<translation id="1342703999636762729">WEB3 DNA Browser কাস্টমাইজ করুন</translation>
<translation id="2174917724755363426">ইনস্টলেশন শেষ হয়নি। আপনি কি সত্যিই বাতিল করতে চান?</translation>
<translation id="4604256298037443917">WEB3 DNA Browser - নেটওয়ার্ক সাইন-ইন - <ph name="PAGE_TITLE" /></translation>
<translation id="3692764894142598026">যদি আপনি একটি কম্পিউটার শেয়ার করেন, তাহলে বন্ধু ও পরিবারের লোকজন পৃথকভাবে ব্রাউজ করতে পারবেন এবং তাদের ইচ্ছা অনুযায়ী WEB3 DNA Browser-এর সেট-আপ করতে পারবেন৷</translation>
<translation id="1653667178840181002">WEB3 DNA Browser-এ স্টোর করা নিরাপদ নয় এমন সাইটের তালিকা থেকে সেগুলির URL গুলি পরীক্ষা করে দেখে। যদি কোনও সাইট আপনার পাসওয়ার্ড চুরি করার চেষ্টা করে বা আপনি কোনও ক্ষতিকারক ফাইল ডাউনলোড করলে, Safe Browsing-এ WEB3 DNA Browser পৃষ্ঠার কিছু কন্টেন্ট সহ URL গুলিও হয়ত পাঠাতে পারে।</translation>
<translation id="4170954887813547201">এখান থেকে আপনার Android ফোনে একটি নম্বর পাঠাতে, উভয় ডিভাইসের WEB3 DNA Browser-এ সাইন-ইন করুন।</translation>
<translation id="7632546848754920458">আপনি WEB3 DNA Browser চালু করলে কোন পৃষ্ঠাটি দেখানো হবে তা এই এক্সটেনশনটি পরিবর্তন করেছে।</translation>
