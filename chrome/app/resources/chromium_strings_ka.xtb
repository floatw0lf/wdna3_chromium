<translation id="386822487697155367">დახმარების მიღება ChromiumOS-თან დაკავშირებით</translation>
<translation id="3532820600057985798">მიიღეთ WEB3 DNA Browser ბრაუზერში შენახული თქვენი კონტენტი <ph name="ACCOUNT_EMAIL" />-დან</translation>
<translation id="3254774751045951355">მოირგეთ და გააკონტროლეთ WEB3 DNA Browser. საჭიროა თქვენი ყურადღება — დააწკაპუნეთ დეტალური ინფორმაციისთვის.</translation>
<translation id="5690972056512883402">WEB3 DNA Browser ის გახსნისა და დათვალიერების დაწყებისათვის დააჭირეთ თქვენი სახელს.</translation>
<translation id="5645023388974281920"><ph name="EXISTING_USER" /> უკვე შესულია ამ WEB3 DNA Browser პროფილში. თქვენი დათვალიერების მონაცემები რომ განაცალკევოთ, WEB3 DNA Browser-ს შეუძლია თქვენთვის პერსონალური პროფილის შექმნა.</translation>
<translation id="8552133641824014764">თქვენს ანგარიშს მართავს <ph name="MANAGER_NAME" />. თქვენს ადმინისტრატორს შეუძლია ამ WEB3 DNA Browser ბრაუზერის პროფილისა და მისი მონაცემების (მაგალითად, სანიშნეების, ისტორიისა და პაროლების) ნახვა და რედაქტირება.</translation>
<translation id="1745190996116952155">WEB3 DNA Browser ცდილობს პაროლების კოპირებას. აღნიშნულის დასაშვებად აკრიფეთ თქვენი Windows-ის პაროლი ამის დასაშვებად.</translation>
<translation id="2363126436977372294">WEB3 DNA Browser გირჩევთ, დაასკანიროთ ეს ფაილი, რადგან ის შეიძლება სახიფათო იყოს</translation>
<translation id="3997429360543082038">ChromiumOS-ის შესახებ</translation>
<translation id="4019629340646866719">ChromiumOS და <ph name="BEGIN_LINK_LINUX_OSS" />Linux-ის შემუშავების გარემო <ph name="END_LINK_LINUX_OSS" /> მუშაობს <ph name="BEGIN_LINK_CROS_OSS" />ღია კოდის დამატებითი პროგრამული უზრუნველყოფის<ph name="END_LINK_CROS_OSS" /> დამსახურებით.</translation>
<translation id="7039332938370903722">ხელი შეუწყვეთ WEB3 DNA Browser-ის გაუმჯობესებას <ph name="BEGIN_LINK" />მიმდინარე პარამეტრების<ph name="END_LINK" /> გამოგზავნის მეშვეობით</translation>
<translation id="4050175100176540509">უსაფრთხოების მნიშვნელოვანი გაუმჯობესება და ახალი თვისებები ხელმისაწვდომია უახლეს ვერსიაში.</translation>
<translation id="4148957013307229264">ინსტალაცია…</translation>
<translation id="9037768363939314060"><ph name="PAGE_TITLE" /> — ქსელში შესვლა — WEB3 DNA Browser</translation>
<translation id="65082721690930806">აღმოაჩინეთ შესანიშნავი აპები, თამაშები, გაფართოებები და თემები WEB3 DNA Browser-ისთვის.</translation>
<translation id="8180918330054927789">ეს ენა გამოიყენება WEB3 DNA Browser-ის სამომხმარებლო ინტერფეისისთვის</translation>
<translation id="4222932583846282852">მიმდინარეობს გაუქმება…</translation>
<translation id="4117615645977273587">დავუკავშიროთ თქვენი WEB3 DNA Browser მონაცემები ამ ანგარიშის?</translation>
<translation id="2562528065031024752">WEB3 DNA Browser-თან დაკავშირებული დახმარების მიღება</translation>
<translation id="4628286205171331451">ინსტალაცია ვერ განხორციელდა განუსაზღვრელი შეცდომის გამო. თუ WEB3 DNA Browser ამჟამად გაშვებულია, დახურეთ იგი და ხელახლა სცადეთ.</translation>
<translation id="4304713468139749426">პაროლების მმართველი</translation>
<translation id="4334294535648607276">ჩამოტვირთვა დასრულდა.</translation>
<translation id="439358628917130594"><ph name="MANAGER" /> მოითხოვს, რომ ამ მოწყობილობის გამოყენებამდე წაიკითხოთ ქვემოთ მოცემული მომსახურების პირობები და დაეთანხმოთ მათ. აღნიშნული პირობები არ არის ChromiumOS-ის წესების დამატება, ასევე, არ ცვლის და არც ზღუდავს მათ.</translation>
<translation id="5363800095683563940">მაინც გსურთ WEB3 DNA Browser-იდან გასვლა?</translation>
<translation id="4413681411297396618">WEB3 DNA Browser-ისთვის ფონურ რეჟიმში მუშაობის დაშვება</translation>
<translation id="4960563596527056032">WEB3 DNA Browser-ის მორგება და კონტროლი</translation>
<translation id="4427306783828095590">გაძლიერებული დაცვა გთავაზობთ ფიშინგისა და მავნე პროგრამებისგან დაცვის მეტ საშუალებას</translation>
<translation id="5075487038316202932">მოგესალმებით WEB3 DNA Browser-ში; გახსნილია ბრაუზერის ახალი ფანჯარა</translation>
<translation id="8333408299151688471">WEB3 DNA Browser-ის განახლება ვერ მოხერხდა შეფერხების გამო. <ph name="BEGIN_LINK" />შეასწორეთ WEB3 DNA Browser-ის განახლებასთან დაკავშირებული პრობლემები და განუხორციელებელი განახლებები.<ph name="END_LINK" /></translation>
<translation id="5710517655208362990">გსურთ ახალ WEB3 DNA Browser პროფილში გაგრძელება?</translation>
<translation id="4567424176335768812">თქვენ შესული ხართ, როგორც <ph name="USER_EMAIL_ADDRESS" />. ახლა შეგიძლიათ გახსნათ თქვენი სანიშნეები, ისტორია და სხვა პარამეტრები ყველა მოწყობილობიდან, რომელშიც შესული ხართ.</translation>
<translation id="4594305310729380060">პაროლების მმართველში ამ მოწყობილობაზე</translation>
<translation id="8700214093481776621">WEB3 DNA Browser პროგრამები</translation>
<translation id="4613863813562375431">ChromiumOS-ის ვერსია</translation>
<translation id="6951246183774166202">განახლება თითქმის მზად არის! დასასრულებლად, ხელახლა გაუშვით WEB3 DNA Browser.</translation>
<translation id="1967316171334904609">გაფრთხილება: WEB3 DNA Browser ვერ შეუშლის ხელს გაფართოებებს დათვალიერების ისტორიის შენახვაში. ინკოგნიტო რეჟიმში ამ გაფართოების გასათიშად მოხსენით მონიშვნა ამ ვარიანტზე.</translation>
<translation id="6242940079717718930">თუ WEB3 DNA Browser-ის მოხმარების ანგარიშებსაც გააზიარებთ, მათ თქვენ მიერ მონახულებულ URL-ებიც დაერთვება</translation>
<translation id="4405105480942922067">როგორც ჩანს, პროფილი გამოიყენება სხვა WEB3 DNA Browser პროცესის მიერ (<ph name="PROCESS_ID" />) სხვა კომპიუტერში (<ph name="HOST_NAME" />). WEB3 DNA Browser-მა დაბლოკა პროფილი, რათა არ დაზიანდეს. თუ დარწმუნებული ხართ, რომ სხვა პროცესები არ იყენებენ ამ პროფილს, შეგიძლიათ განბლოკოთ პროფილი და ხელახლა გაუშვათ WEB3 DNA Browser.</translation>
<translation id="4680828127924988555">ინსტალაციის გაუქმება</translation>
<translation id="3750760070906465924">WEB3 DNA Browser-ში უკვე განხორციელდა შესვლა ამ კომპიუტერიდან, როგორც <ph name="ACCOUNT_EMAIL_LAST" />. გთხოვთ, შექმნათ WEB3 DNA Browser-ის ახალი მომხმარებელი თქვენი ინფორმაციის ცალკე შესანახად.</translation>
<translation id="1217313267986183942">მაინც გსურთ WEB3 DNA Browser-იდან გასვლა?</translation>
<translation id="4805555266423130696">WEB3 DNA Browser-ს ეს-ესაა მიესადაგა უსაფრთხოების საგანგებო განახლება. გადატვირთეთ ის ახლავე (თქვენი ჩანართები აღდგება).</translation>
<translation id="3541589509773411057">აზრის შეცვლას ნებისმიერ დროს შეძლებთ WEB3 DNA Browser-ის პარამეტრებიდან. ცდები განხორციელდება რეკლამის ჩვენების ამჟამინდელი მექანიზმების მოქმედების პარალელურად, ამიტომ ცვლილებებს მომენტალურად არ შეამჩნევთ.</translation>
<translation id="2655572098566031184">WEB3 DNA Browser ვერ ახერხებს პაროლების შემოწმებას. ცადეთ 24 საათში ან <ph name="BEGIN_LINK" />შეამოწმეთ პაროლები თქვენს Google ანგარიშში<ph name="END_LINK" />.</translation>
<translation id="479167709087336770">ეს ფუნქცია იყენებს მართლწერის იმ შემმოწმებელს, რომელიც გამოიყენება Google Search-ში. ბრაუზერში თქვენ მიერ აკრეფილი ტექსტი ეგზავნება Google-ს. ამ ქცევის შეცვლა ნებისმიერ დროს შეგიძლიათ პარამეტრებიდან.</translation>
<translation id="6402416911698425675">WEB3 DNA Browser-ის შემავალი წესი დაუშვას mDNS მოძრაობა.</translation>
<translation id="5496148131599227635">ხელახლა გაშვება &amp;WEB3 DNA Browser-ის გასაახლებლად</translation>
<translation id="3889712706226772861">WEB3 DNA Browser ფონურ რეჟიმშია.</translation>
<translation id="5502939625951695202">სტუმრებს შეუძლიათ WEB3 DNA Browser-ის გამოყენება და მისი ყველა ფუნქციით სარგებლობა.</translation>
<translation id="4935574428555172200">საკუთარი თავის დამატება WEB3 DNA Browser-ში</translation>
<translation id="60503244591890876">WEB3 DNA Browser მუშაობს ახალ ფუნქციებზე, რომელთა მეშვეობითაც საიტებს იგივე ფუნქციონალი შეუნარჩუნდება თქვენი ნაკლები ინფორმაციის გამოყენებით</translation>
<translation id="282690038359289128">შენახული პაროლები არ არის. პაროლების შემოწმებას WEB3 DNA Browser შეძლებს მათი შენახვის შემდეგ.</translation>
<translation id="3588920839125338516"><ph name="EXISTING_USER" /> უკვე შესულია ამ WEB3 DNA Browser პროფილში. ეს მოქმედება შექმნის ახალ WEB3 DNA Browser პროფილს <ph name="USER_EMAIL_ADDRESS" />-ისთვის</translation>
<translation id="1712448899328197828">ცვლილებების მისასადაგებლად ხელახლა გაუშვით WEB3 DNA Browser</translation>
<translation id="5425968257754155673">როცა ცდები ჩართულია და თუ WEB3 DNA Browser შემთხვევითობის პრინციპით მიგაღებინებთ მონაწილეობას მიმდინარე ცდაში, თქვენ მიერ ვების დათვალიერების ისტორია აისახება თქვენთვის ხილულ რეკლამასა და თქვენს ინტერესებზე, ქვემოთ პროგნოზირებულის შესაბამისად. თქვენი კონფიდენციალურობის დაცვის მიზნით, WEB3 DNA Browser წაშლის თქვენს ინტერესებს ყოველთვიურად რიგითობის მიხედვით.</translation>
<translation id="4715135477147720071">მართული ანგარიშით შედიხართ სისტემაში და ადმინისტრატორს თქვენს WEB3 DNA Browser-ის პროფილზე კონტროლს აძლევთ. თქვენი WEB3 DNA Browser ის მონაცემები როგორიცაა თქვენი აპლიკაციები, სანიშნები, ისტორიები, პაროლები, და სხვა პარამეტრები მუდმივად მიბმული გახდება <ph name="USER_NAME" />-თან. ამ მონაცემების წაშლას Google ანგარიშის საინფორმაციო დაფის გზით შეძლებთ, მაგრამ შეუძლებელი იქნება ამ მონაცემების სხვა ანგარიშთან გაერთიანება. <ph name="LEARN_MORE" /></translation>
<translation id="3959775081883542439">მიმდინარეობს WEB3 DNA Browser-ის განახლება (<ph name="PROGRESS_PERCENT" />)</translation>
<translation id="8468846229743402892">WEB3 DNA Browser-ში შესვლის დაშვება</translation>
<translation id="868709743621506099">ხელმისაწვდომია WEB3 DNA Browser-ის ახალი ვერსია.</translation>
<translation id="8954902894032987165">WEB3 DNA Browser-იდან ამოღება</translation>
<translation id="8529594966625997901">{0,plural, =0{WEB3 DNA Browser ახლა დაიხურება.}=1{WEB3 DNA Browser დაიხურება 1 წამში.}other{WEB3 DNA Browser დაიხურება # წამში.}}</translation>
<translation id="2581842036863502750">დააყენეთ WEB3 DNA Browser ნაგულისხმევ ბრაუზერად</translation>
<translation id="2775837035201231287"><ph name="PAGE_TITLE" /> — WEB3 DNA Browser Beta</translation>
<translation id="3342188394733679831">WEB3 DNA Browser-მა შეიძლება არასწორად იმუშაოს, რადგან ის აღარ არის მხარდაჭერილი ამ Linux დისტრიბუტივზე</translation>
<translation id="6744035239102820989">WEB3 DNA Browser საჭიროებს თქვენს მდებარეობაზე წვდომის ნებართვას ამ საიტისთვის გასაზიარებლად</translation>
<translation id="1336779017674457494">თქვენი კონფიდენციალურობის დაცვის მიზნით, ჩვენ ავტომატურად ვშლით თქვენს ინტერესებს, რომლებიც 4 კვირაზე ძველია. თქვენ მიერ ვების დათვალიერების პარალელურად, ესა თუ ეს ინტერესი შეიძლება ხელახლა გამოჩნდეს სიაში. თუ WEB3 DNA Browser შეცდომით გამოიცნობს თქვენს ინტერესს, ან რომელიმე ტიპის რეკლამის ნახვას არ მოისურვებთ, ინტერესის წაშლის საშუალება გექნებათ.</translation>
