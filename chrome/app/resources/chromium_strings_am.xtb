<translation id="386822487697155367">ChromiumOS ላይ እገዛ ያግኙ</translation>
<translation id="3532820600057985798">የWEB3 DNA Browser አሳሽ ነገሮችዎን ከ<ph name="ACCOUNT_EMAIL" /> ያግኙ</translation>
<translation id="3254774751045951355">WEB3 DNA Browserን ያብጁ እና ይቆጣጠሩ። የሆነ ነገር ትኩረትዎ ያስፈልገዋል - ለዝርዝሮች ጠቅ ያድርጉ።</translation>
<translation id="5690972056512883402">WEB3 DNA Browserን ለመክፈት እና ማሰስ ለመጀመር ስምዎን ጠቅ ያድርጉት።</translation>
<translation id="5645023388974281920"><ph name="EXISTING_USER" /> አስቀድመው ወደዚህ የWEB3 DNA Browser መገለጫ ገብተዋል። አሰሳዎን የተለየ እንደሆነ ለማቆየት WEB3 DNA Browser የራስዎን መገለጫ ለእርስዎ መፍጠር ይችላል።</translation>
<translation id="8552133641824014764">የእርስዎ መለያ የሚተዳደረው በ<ph name="MANAGER_NAME" /> ነው። የእርስዎ አስተዳዳሪ ይህንን የWEB3 DNA Browser አሳሽ መገለጫ እና እንደ እልባቶች፣ ታሪክ እና የይለፍ ቃላት ያሉ ውሂቡን መመልከት እና ማርትዕ ይችላሉ።</translation>
<translation id="1745190996116952155">WEB3 DNA Browser የይለፍ ቃላትን ለመቅዳት እየሞከረ ነው። ይህንን ለመፍቀድ የWindows የይለፍ ቃልዎን ይተይቡ።</translation>
<translation id="2363126436977372294">WEB3 DNA Browser ይህ ፋይል አደገኛ ሊሆን ስለሚችል እንዲቃኙት ይመክራል</translation>
<translation id="3997429360543082038">ስለChromiumOS</translation>
<translation id="4019629340646866719">ChromiumOS እና <ph name="BEGIN_LINK_LINUX_OSS" />የLinux ግንባታ ምህዳር<ph name="END_LINK_LINUX_OSS" /> ሊሠሩ የቻሉት በተጨማሪ <ph name="BEGIN_LINK_CROS_OSS" />የክፍት ምንጭ ሶፍትዌር<ph name="END_LINK_CROS_OSS" /> ነው።</translation>
<translation id="7039332938370903722"><ph name="BEGIN_LINK" />የአሁኖቹን ቅንብሮች<ph name="END_LINK" /> ሪፖርት በማድረግ WEB3 DNA Browser የተሻለ እንዲሆን ያግዙ</translation>
<translation id="4050175100176540509">አስፈላጊ የደህንነት ማሻሻያዎች እና አዲስ ባህሪያት በቅርብ ጊዜው ስሪቱ ላይ ይገኛሉ።</translation>
<translation id="4148957013307229264">በመጫን ላይ...</translation>
<translation id="9037768363939314060"><ph name="PAGE_TITLE" /> - በአውታረ መረብ ወደ መለያ መግባት - WEB3 DNA Browser</translation>
<translation id="65082721690930806">ለWEB3 DNA Browser ምርጥ መተግበሪያዎችን፣ ጨዋታዎችን፣ ቅጥያዎችን እና ገጽታዎችን ያግኙ።</translation>
<translation id="8180918330054927789">ይህ ቋንቋ የWEB3 DNA Browser ዩአይን ለማሳየት ስራ ላይ ይውላል</translation>
<translation id="4222932583846282852">በመሰረዝ ላይ...</translation>
<translation id="4117615645977273587">የWEB3 DNA Browser ውሂዎ ከዚህ መለያ ጋር ይገናኝ?</translation>
<translation id="2562528065031024752">WEB3 DNA Browser ላይ እገዛ ያግኙ</translation>
<translation id="4628286205171331451">ተለይቶ ባልታወቀ ስህተት ምክንያት ጭነት ከሽፏል። WEB3 DNA Browser አሁን እያሄደ ከሆነ እባክዎ ይዝጉትና እንደገና ይሞክሩ።</translation>
<translation id="4304713468139749426">የይለፍ ቃል አስተዳዳሪ</translation>
<translation id="4334294535648607276">ማውረድ ተጠናቅቋል።</translation>
<translation id="439358628917130594"><ph name="MANAGER" /> ይህን መሣሪያ ከመጠቀምዎ በፊት የሚከተለውን የአገልግሎት ውል እንዲያነብቡት እና እንዲቀበሉት ይፈለጋል። ይህ ውል የChromiumOS ውሉን አያስፋፋውም፣ አይቀይረውም ወይም አይገድበውም።</translation>
<translation id="5363800095683563940">የሆነው ሆኖ ከWEB3 DNA Browser ይወጣ?</translation>
<translation id="4413681411297396618">WEB3 DNA Browser በበስተጀርባ ላይ ያሂድ</translation>
<translation id="4960563596527056032">WEB3 DNA Browserን ያብጁ እና ይቆጣጠሩ</translation>
<translation id="4427306783828095590">የተሻሻለ ጥበቃ ማስገር እና ተንኮል-አዘል ዌር ለማገድ የበለጠ ይሠራል</translation>
<translation id="5075487038316202932">እንኳን ወደ WEB3 DNA Browser በደህና መጡ፤ አዲስ የአሳሽ መስኮት ተከፍቷል</translation>
<translation id="8333408299151688471">WEB3 DNA Browser አልተዘመነም፣ የሆነ ችግር ተፈጥሯል። <ph name="BEGIN_LINK" />የWEB3 DNA Browser ዝማኔ ችግሮችን እና ያልተሳኩ ዝማኔዎችን ያስተካክሉ።<ph name="END_LINK" /></translation>
<translation id="5710517655208362990">በአዲሱ የWEB3 DNA Browser መገለጫ ውስጥ ይቀጥል?</translation>
<translation id="4567424176335768812">እንደ <ph name="USER_EMAIL_ADDRESS" /> ሆነው ገብተዋል። አሁን የእርስዎን ዕልባቶች፣ ታሪክ እና ሌሎች ቅንብሮች በመለያ በገቡ ሁሉም መሣሪያዎችዎ ላይ መድረስ ይችላሉ።</translation>
<translation id="4594305310729380060">በዚህ መሣሪያ ላይ ወደ የይለፍ ቃል አስተዳዳሪ</translation>
<translation id="8700214093481776621">የWEB3 DNA Browser መተግበሪያዎች</translation>
<translation id="4613863813562375431">የChromiumOS ስሪት</translation>
<translation id="6951246183774166202">የተዘመነ ለመሆን ጥቂት ብቻ ቀርቷል! ማዘመን ለማጠናቀቅ WEB3 DNA Browserን ዳግም ያስጀምሩት።</translation>
<translation id="1967316171334904609">ማስጠንቀቂያ፦ WEB3 DNA Browser ቅጥያዎች የአሰሳ ታሪክዎን እንዳይመዘግቡ መከልከል አይችልም። ይህን ቅጥያ ማንነት በማያሳውቅ ሁነት ላይ ለማሰናከል ይህን አማራጭ አይምረጡ።</translation>
<translation id="6242940079717718930">እንዲሁም የWEB3 DNA Browser አጠቃቀም ሪፖርቶችን ካጋሩ፣ እነዚያ ሪፖርቶች እርስዎ የሚጎበኟቸውን ዩአርኤሎች ያካትታሉ</translation>
<translation id="4405105480942922067">መገለጫው በሌላ ኮምፒውተር (<ph name="HOST_NAME" />) ላይ በሌላ የWEB3 DNA Browser ሂደት (<ph name="PROCESS_ID" />) የተያዘ ይመስላል። WEB3 DNA Browser መገለጫው እንዳይበላሽ ቆልፎታል።  ሌሎች ሂደቶች ይህን መገለጫ እየተጠቀሙበት እንዳልሆኑ እርግጠኛ ከሆኑ መገለጫውን አስከፍተው WEB3 DNA Browserን ዳግም ማስጀመር ይችላሉ።</translation>
<translation id="4680828127924988555">መጫኑን ሰርዝ</translation>
<translation id="3750760070906465924">የሆነ ሰው ከዚህ ቀደም በዚህ ኮምፒውተር ላይ እንደ <ph name="ACCOUNT_EMAIL_LAST" /> ሆነው ገብተዋል። የእርስዎን መረጃ ለይተው ለማስቀመጥ እባክዎ አዲስ የWEB3 DNA Browser ተጠቃሚ ይፍጠሩ።</translation>
<translation id="1217313267986183942">የሆነው ሆኖ WEB3 DNA Browser ይቁም?</translation>
<translation id="4805555266423130696">ለWEB3 DNA Browser ልዩ የደህንነት ዝማኔ ተፈጻሚ ተደርጓል። አሁን ዳግም ያስጀምሩ እና የእርስዎን ትሮች ወደ ነበሩበት እንመልሳለን።</translation>
<translation id="3541589509773411057">በWEB3 DNA Browser ቅንብሮች ውስጥ ሐሳብዎን በማንኛውም ጊዜ መቀየር ይችላሉ። ሙከራዎቹ ማስታወቂያዎች የሚስተናገዱበት መንገድ ጋር አብረው ይሄዳሉ፣ ስለሆነም ለውጦችን ወዲያውኑ ማየት አይችሉም።</translation>
<translation id="2655572098566031184">WEB3 DNA Browser የእርስዎን የይለፍ ቃላት መፈተሽ አይችልም። ከ24 ሰዓቶች በኋላ እንደገና ይሞክሩ ወይም <ph name="BEGIN_LINK" />በGoogle መለያዎ ውስጥ የይለፍ ቃላትን ይፈትሹ<ph name="END_LINK" />።</translation>
<translation id="479167709087336770">ይህ በ Google ፍለጋ ውስጥ ጥቅም ላይ ጋር ተመሳሳይ የፊደል አራሚ ይጠቀማል። በአሳሽ ውስጥ የሚተይቡት ጽሁፍ ወደ Google ይላካል። ይህን ባህሪ ሁልጊዜ በቅንብሮች ውስጥ መለወጥ ይችላሉ።</translation>
<translation id="6402416911698425675">WEB3 DNA Browser ለmDNS ትራፊክ ለመፍቀድ የውስጥ ደንብ።</translation>
<translation id="5496148131599227635">&amp;WEB3 DNA Browserን ለማዘመን ዳግም ያስነሱት</translation>
<translation id="3889712706226772861">WEB3 DNA Browser በጀርባ ሁነታ ላይ ነው።</translation>
<translation id="5502939625951695202">እንግዳዎች ማንኛውንም ነገር ወደኋላ ሳይተዉ WEB3 DNA Browser መጠቀም ይችላሉ።</translation>
<translation id="4935574428555172200">እራስዎን በWEB3 DNA Browser ላይ ያክሉ</translation>
<translation id="60503244591890876">WEB3 DNA Browser ጣቢያዎች ያነሰ መረጃዎን ተጠቅመው ተመሳሳይ የአሰሳ ተሞክሮ እንዲያቀርቡ የሚያስችሏቸውን አዳዲስ ባህሪያትን እያሰሰ ነው።</translation>
<translation id="282690038359289128">ምንም የተቀመጡ የይለፍ ቃላት የሉም። እርስዎ የይለፍ ቃላትዎን ሲያስቀምጧቸው WEB3 DNA Browser መፈተሽ ይችላል።</translation>
<translation id="3588920839125338516"><ph name="EXISTING_USER" /> አስቀድመው ወደዚህ የWEB3 DNA Browser መገለጫ ገብተዋል። ይህ አዲስ የWEB3 DNA Browser መገለጫ ለ<ph name="USER_EMAIL_ADDRESS" /> ይፈጥራል</translation>
<translation id="1712448899328197828">የእርስዎን ለውጦች ተፈጻሚ ለማድረግ፣ WEB3 DNA Browserን ዳግም ያስጀምሩ</translation>
<translation id="5425968257754155673">ሙከራዎች ሲበሩ እና WEB3 DNA Browser በዘፈቀደ እርስዎን በገቢር ሙከራ ካስቀመጠ የአሰሳ ታሪክዎ በሚያዩዋቸው ማስታወቂያዎች እና ከታች በተገመተው ዝንባሌዎች ላይ ተጽዕኖ ይኖረዋል። የእርስዎን ግላዊነት ለመጠበቅ WEB3 DNA Browser በየወሩ ዝንባሌዎችዎን ይሰርዛል።</translation>
<translation id="4715135477147720071">በሚተዳደር መለያ እየገቡ ነው፣ እና አስተዳዳሪው በእርስዎ WEB3 DNA Browser መገለጫ ላይ ቁጥጥር እየሰጡት ነው። እንደ እርስዎ  መተግበሪያዎች፣ ዕልባቶች፣ ታሪክ፣ የይለፍ ቃላት እና ሌሎች ቅንብሮች ያሉ የእርስዎ WEB3 DNA Browser ውሂብ እስከ መጨረሻው ከ<ph name="USER_NAME" /> ጋር የተያያዙ ይሆናሉ። ይህን ውሂብ በGoogle የመለያዎች Dashboard አማካኝነት ሊሰርዙት ይችላሉ፣ ነገር ግን ይህን ውሂብ ከሌላ መለያ ጋር ሊያጎዳኙት አይችሉም። <ph name="LEARN_MORE" /></translation>
<translation id="3959775081883542439">WEB3 DNA Browserን በማዘመን ላይ (<ph name="PROGRESS_PERCENT" />)</translation>
<translation id="8468846229743402892">የWEB3 DNA Browser በመለያ መግባትን ይፍቀዱ</translation>
<translation id="868709743621506099">አዲስ የWEB3 DNA Browser ስሪት አለ።</translation>
<translation id="8954902894032987165">ከWEB3 DNA Browser አስወግድ</translation>
<translation id="8529594966625997901">{0,plural, =0{WEB3 DNA Browser አሁን ይዘጋል።}=1{WEB3 DNA Browser በ1 ሰከንድ ውስጥ ይዘጋል።}one{WEB3 DNA Browser በ# ሰከንድ ውስጥ ይዘጋል።}other{WEB3 DNA Browser በ# ሰከንዶች ውስጥ ይዘጋል።}}</translation>
<translation id="2581842036863502750">WEB3 DNA Browser እንደ ነባሪ አሳሽዎ አድርገው ያዋቅሩት</translation>
<translation id="2775837035201231287"><ph name="PAGE_TITLE" /> - WEB3 DNA Browser ቅድመ-ይሁንታ</translation>
<translation id="3342188394733679831">በዚህ የLinux ስርጭት ላይ ከእንግዲህ ስለማይደገፍ WEB3 DNA Browser በአግባቡ ላይሰራ ይችላል።</translation>
<translation id="6744035239102820989">WEB3 DNA Browser አካባቢዎን ለዚህ ጣቢያ ለማጋራት የአካባቢዎ መዳረሻ ያስፈልገዋል</translation>
<translation id="1336779017674457494">የእርስዎን ግላዊነት ለመጠበቅ ከ4 ሳምንታት በላይ የቆዩ ዝንባሌዎችዎን በራስ-ሰር እንሰርዛለን። ማሰስዎን በሚቀጥሉበት ጊዜ ዝንባሌ እንደገና በዝርዝሩ ላይ ሊታይ ይችላል። እና WEB3 DNA Browser ከተሳሳተ ወይም የተወሰኑ ማስታወቂያዎችን ማየት ካልፈለጉ ዝንባሌን ማስወገድ ይችላሉ።</translation>
<translation id="5998903067774658363">WEB3 DNA Browser የቅርብ ጊዜዎቹ የስርዓቱ ዝማኔዎችን እስኪጭን ድረስ እባክዎ ይጠብቁ።</translation>
<translation id="840929360644660930">WEB3 DNA Browser የይለፍ ቃላትን ለማርትዕ እየሞከረ ነው። ይህንን ለመፍቀድ የWindows የይለፍ ቃልዎን ይተይቡ።</translation>
