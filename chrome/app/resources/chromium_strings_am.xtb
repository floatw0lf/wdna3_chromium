<translation id="2558936839934178842">ይሄ <ph name="ITEMS_COUNT" /> ንጥሎችን ከዚህ መሣሪያ ይሰርዛል። ውሂብዎን በኋላ ላይ ሰርስረው ለማውጣት እንደ <ph name="USER_EMAIL" /> ሆነው ወደ WEB3 DNA Browser ይግቡ።</translation>
<translation id="3356184603360407459"><ph name="SHORTCUT" /> በWEB3 DNA Browser መገለጫዎች መካከል መቀያየር ይችላል</translation>
<translation id="4904006555695224532">እባክዎ ሁሉንም የWEB3 DNA Browser መስኮቶችን ይዝጉና እንደገና ይሞክሩ።</translation>
<translation id="1702866421814791137">በWEB3 DNA Browser ውስጥ የGoogle ረዳት በመላ ድር ጣቢያዎች ውስጥ ለእርስዎ እርምጃዎችን ማጠናቀቅ ይችላል</translation>
<translation id="5618636199529337261">የእርስዎን ግላዊነት ለመጠበቅ ከ4 ሳምንታት በላይ የቆዩ ዝንባሌዎችዎን በራስ-ሰር እንሰርዛለን። ማሰስዎን በሚቀጥሉበት ጊዜ ዝንባሌ እንደገና በዝርዝሩ ላይ ሊታይ ይችላል። ወይም WEB3 DNA Browser ከግምት ውስጥ እንዳያስገባቸው የማይፈልጓቸውን ዝንባሌዎች ማስወገድ ይችላሉ።</translation>
<translation id="319672769194370808">የአሰሳ ታሪክዎ፣ በዚህ መሣሪያ ላይ WEB3 DNA Browserን ተጠቅመው የጎበኟቸው የጣቢያዎች መዝገብ።</translation>
<translation id="4060507003609322665">በእርስዎ ኮምፒውተር ላይ ጎጂ ሶፍትዌር አለ። WEB3 DNA Browser የእርስዎን አሰሳ እንደገና በጤናማነት እንዲሠራ ለማድረግ ሊያስወግደው፣ የእርስዎን ቅንብሮች እንደነበሩ ሊመልሳቸው እና ቅጥያዎችን ሊያሰናክል ይችላል።</translation>
<translation id="6858481853319304501">ሌላ መለያ አስቀድሞ ገብቷል። አሰሳዎን ለይቶ ለማቆየት WEB3 DNA Browser የራስዎን መገለጫ ለእርስዎ መፍጠር ይችላል።</translation>
<translation id="7181053905423306884">ይህ ሰው የአሰሳ ውሂብ ከዚህ መሣሪያ ይሰረዛል። ውሂቡን መልሶ ለማግኘት እንደ <ph name="USER_EMAIL" /> ሆነው ወደ WEB3 DNA Browser ይግቡ።</translation>
<translation id="8833453854863974594">{COUNT,plural, =0{አዲስ ዝማኔ ለWEB3 DNA Browser የሚገኝ ሲሆን ልክ ዳግም ሲያስጀምሩት ይተገበራል።}=1{አዲስ ዝማኔ ለWEB3 DNA Browser የሚገኝ ሲሆን ልክ ዳግም ሲያስጀምሩት ይተገበራል። የእርስዎ ማንነት የማያሳውቅ መስኮት ዳግም አይከፈትም}one{አዲስ ዝማኔ ለWEB3 DNA Browser የሚገኝ ሲሆን ልክ ዳግም ሲያስጀምሩት ይተገበራል። የእርስዎ # ማንነት የማያሳውቁ መስኮቶች ዳግም አይከፈቱም}other{አዲስ ዝማኔ ለWEB3 DNA Browser የሚገኝ ሲሆን ልክ ዳግም ሲያስጀምሩት ይተገበራል። የእርስዎ # ማንነት የማያሳውቁ መስኮቶች ዳግም አይከፈቱም}}</translation>
<translation id="890421963650512515">አንድ ቁጥር ከ<ph name="ORIGIN" /> ወደ የእርስዎ Android ስልክ ለመላክ በሁለቱም መሣሪያዎች ላይ በመለያ ወደ WEB3 DNA Browser ይግቡ።</translation>
<translation id="8559660999448670332">WEB3 DNA Browser የእርስዎን የይለፍ ቃላት መፈተሽ አይችልም። የበይነመረብ ግንኙነትዎን ለመፈተሽ ይሞክሩ።</translation>
<translation id="2460459186000985919">በWEB3 DNA Browser ውስጥ ማስታወቂያን ግላዊነት ስለማላበስ የበለጠ ይወቁ</translation>
<translation id="1249507445971540698">{COUNT,plural, =0{ይህን ዝማኔ ለመተግበር አስተዳዳሪዎ WEB3 DNA Browserን ዳግም እንዲያስጀምሩት ይጠይቀዎታል}=1{ይህን ዝማኔ ለመተግበር አስተዳዳሪዎ WEB3 DNA Browserን ዳግም እንዲያስጀምሩት ይጠይቀዎታል የእርስዎ ማንነት የማያሳውቅ መስኮት ዳግም አይከፈትም}one{ይህን ዝማኔ ለመተግበር አስተዳዳሪዎ WEB3 DNA Browserን ዳግም እንዲያስጀምሩት ይጠይቀዎታል የእርስዎ # ማንነት የማያሳውቁ መስኮቶች ዳግም አይከፈቱም}other{ይህን ዝማኔ ለመተግበር አስተዳዳሪዎ WEB3 DNA Browserን ዳግም እንዲያስጀምሩት ይጠይቀዎታል የእርስዎ # ማንነት የማያሳውቁ መስኮቶች ዳግም አይከፈቱም}}</translation>
<translation id="8552541042755991172">አገናኙን በWEB3 DNA Browser አዲስ &amp;ትር ውስጥ ክፈት</translation>
<translation id="6916875900143115982">WEB3 DNA Browser የእርስዎን Drive በአድራሻ አሞሌ ውስጥ ጥቆማ ሐሳቦችን ይደርሳል።</translation>
<translation id="336867116231879142">WEB3 DNA Browser ድር ላይ ያለ ስልክ ቁጥር ጠቅ እንዲያደርጉትና በSkype እንዲደውሉበት ያስችልዎታል!</translation>
<translation id="3830894615770080216">የChromiumOS ስርዓት</translation>
