<translation id="8502268940781535829">ይህን መለያ ያለው አንድ የWEB3 DNA Browser መገለጫ አስቀድሞ በዚህ መሣሪያ ላይ አለ</translation>
<translation id="7845233973568007926">ሰለተጫኑ እናመሰግናለን። <ph name="BUNDLE_NAME" />ን ከመጠቀምዎ በፊት ኮምፒውተርዎን እንደገና ማስጀመር አለብዎት።</translation>
<translation id="5422417406245013307">WEB3 DNA Browser ወደ የቅርብ ጊዜው ስሪት ሊዘመን አልቻለም፣ ስለዚህ አዲስ ባህሪያት እና የደህንነት ጥገናዎች እያመለጡዎት ናቸው። WEB3 DNA Browserን ማዘመን አለብዎት።</translation>
<translation id="7872446069773932638">በማውረድ ላይ... <ph name="SECONDS" /> ሰከንድ(ዶች) ይቀራሉ</translation>
<translation id="6590823489474620893"><ph name="BEGIN_BOLD" />የእርስዎን ውሂብ እንዴት ማቀናበር እንደሚችሉ፦<ph name="END_BOLD" /> የእርስዎን ግላዊነት ለመጠበቅ ከ4 ሳምንታት በላይ የቆዩ ዝንባሌዎችዎን በራስ-ሰር እንሰርዛለን። ማሰስዎን በሚቀጥሉበት ጊዜ ዝንባሌ እንደገና በዝርዝሩ ላይ ሊታይ ይችላል። ወይም WEB3 DNA Browser ከግምት ውስጥ እንዳያስገባቸው የማይፈልጓቸውን ዝንባሌዎች ማስወገድ ይችላሉ።</translation>
<translation id="7280500878215405781">እንደ <ph name="USER_EMAIL_ADDRESS" /> ሆነው ወደ WEB3 DNA Browser ገብተዋል። እባክዎ እንደገና ለመግባት ተመሳሳዩን መለያ ይጠቀሙ።</translation>
<translation id="2253021454574730566">ይሄ ሁለተኛ የWEB3 DNA Browser ጭነት ነው፣ እና ነባሪ አሳሽዎ ማድረግ አይቻልም።</translation>
<translation id="2180063386451170761">ካልታወቁ ምንጮች የመጡ ቅጥያዎች፣ መተግበሪያዎች እና ገጽታዎች መሣሪያዎን ሊጎዱ ይችላሉ። WEB3 DNA Browser እነሱን ከ<ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> ብቻ መጫንን ይመክራል</translation>
<translation id="1446133009793910887">አንዴ WEB3 DNA Browser መዳረሻ ከኖረው በኋላ ድር ጣቢያዎች እርስዎን መዳረሻ መጠየቅ ይችላሉ።</translation>
<translation id="80471789339884597">ሰለተጫኑ እናመሰግናለን። <ph name="BUNDLE_NAME" />ን ከመጠቀምዎ በፊት ሁሉንም አሳሾችዎን እንደገና ማስጀመር አለብዎት።</translation>
<translation id="3869525261991846539">WEB3 DNA Browser ለዚህ ጣቢያ የአካባቢ ፈቃድ ያስፈልገዋል</translation>
<translation id="8133124826068723441">ማስመር ለጎራዎ ስለማይገኝ ChromiumOS ውሂብዎን ማስመር አይችልም።</translation>
<translation id="813913629614996137">በማስጀመር ላይ…</translation>
<translation id="6871375725780252705">ይህ ፋይል አደገኛ ስለሆነ WEB3 DNA Browser አግዶታል።</translation>
<translation id="8821717781402291672">እንደዚህ አይነት ፋይል አደገኛ ስለሆነ WEB3 DNA Browser ይህን ፋይል አግዶታል።</translation>
<translation id="8394136310056741303">አንድ ምስል ጠቃሚ መግለጫ ከሌለው WEB3 DNA Browser ለእርስዎ አንድ ለማቅረብ ይሞክራል። ዝርዝር መግለጫዎችን ለመፍጠር፣ ምስሎች ወደ Google ይላካሉ። ይህን በማንኛውም ጊዜ በቅንብሮች ውስጥ ሊያጠፉት ይችላሉ።</translation>
<translation id="4863557335992202213">እርስዎ በመለያ ስላልገቡ ስለሆኑ WEB3 DNA Browser የይለፍ ቃላትዎን መፈተሽ አይችልም</translation>
<translation id="8332908002682218419">WEB3 DNA Browser የይለፍ ቃላትን ለመቅዳት እየሞከረ ነው።</translation>
<translation id="3862328687893385239">ይህ ፋይል አደገኛ ሊሆን ስለሚችል WEB3 DNA Browser አግዶታል።</translation>
<translation id="7450630974943556627">WEB3 DNA Browserን በመላ መሣሪያዎችዎ ላይ ለማሳመር እና ግላዊነት ለማላበስ</translation>
<translation id="8910359951607649198"><ph name="USER_EMAIL_ADDRESS" /> ከዚህ ቀደም WEB3 DNA Browserን እየተጠቀመ ነበር</translation>
<translation id="7837286795552251352">በሁሉም መሣሪያዎችዎ ላይ የእርስዎን የWEB3 DNA Browser አሳሽ ነገሮች ለመድረስ ይግቡ፣ ከዚያ ስምረትን ያብሩ</translation>
<translation id="4231941262737361466">የወደፊት የWEB3 DNA Browser ዝማኔዎችን ለማግኘት Windows 10 ወይም ከዚያ በላይ ያስፈልግዎታል። ይህ ኮምፒውተር Windows 8 እየተጠቀመ ነው።</translation>
<translation id="4708615805477131870">{0,plural, =1{በአንድ ቀን ውስጥ WEB3 DNA Browserን ዳግም አስጀምር}one{በ# ቀኖች ውስጥ WEB3 DNA Browserን ዳግም አስጀምር}other{በ# ቀኖች ውስጥ WEB3 DNA Browserን ዳግም አስጀምር}}</translation>
<translation id="8293407095466346653">የጫኚው መዝገብ ተበላሽቷል ወይም ትክክል አይደለም። እባክዎ WEB3 DNA Browserን እንደገና ያውርዱ።</translation>
<translation id="8463672209299734063">ከተፈለገ፦ የምርመራ እና የአጠቃቀም ውሂብ ወደ Google በራስ-ሰር በመላክ የChromiumOS ባህሪያትን እና አፈጻጸምን እንዲሻሻል ያግዙ።</translation>
<translation id="2275026549113043779">WEB3 DNA Browser ጊዜው አልፎበታል</translation>
<translation id="8550334526674375523">ይህ የስራ መገለጫ ከግል መገለጫዎ ሙሉ ለሙሉ የተለየ ነው።</translation>
<translation id="3829194378861761606">የእርስዎ ወላጅ ለWEB3 DNA Browser «የጣቢያዎች፣ መተግበሪያዎች እና ቅጥያዎች ፈቃዶች»ን አጥፍተዋል። ይህን <ph name="EXTENSION_TYPE_PARAMETER" /> ማከል አይፈቀድም።</translation>
<translation id="6148620910029690666">የወደፊቱን የWEB3 DNA Browser ዝመኔዎችን ለማግኘት፣ macOS 10.13 ወይም ከዚያ በኋላ ያለው ያስፈልግዎታል። ይህ ኮምፒተር macOS 10.12 እየተጠቀመ ነው።</translation>
<translation id="1246723111619277441">WEB3 DNA Browser በእርስዎ የGoogle መለያ በሚገቡበት ጊዜ የእርስዎን የይለፍ ቃላትን ሊፈትሽ ይችላል</translation>
<translation id="7115352036028984404">ሲበራ፣ WEB3 DNA Browser የዳራ እንቅስቃሴን እና እንደ ለስላሳ ሽብለላ እና የቪድዮ የክፈፍ ፍጥነቶች ያሉ ምስላዊ ተጽዕኖዎችን በመገደብ የባትሪ ኃይልን ይቆጥባል። <ph name="BEGIN_LINK" />የበለጠ ለመረዳት<ph name="END_LINK" /></translation>
<translation id="4799188800355420938">የቅጂ መብት <ph name="YEAR" /> የWEB3 DNA Browser ደራሲያን። ሁሉም መብቶች የተጠበቁ ናቸው።</translation>
<translation id="1392803118131207008"><ph name="BEGIN_BOLD" />ይህንን ውሂብ እንዴት እንደሚጠቀሙበት፦<ph name="END_BOLD" /> ጣቢያዎች ስለዝንባሌዎችዎ መረጃን በWEB3 DNA Browser አማካኝነት ማከማቸት ይችላሉ። ለምሳሌ፣ ለማራቶን ጫማ ለመግዛት ጣቢያን ከጎበኙ ጣቢያው ዝንባሌዎን እንደ ማራቶን መሮጥ ሊገልጽ ይችላል። በኋላ ላይ ለሩጫ ለመመዝገብ ሌላ ጣቢያ ከጎበኙ ይህ ጣቢያ በዝንባሌዎችዎ ላይ ተመስርቶ የመሮጫ ጫማ ማስታወቂያ ሊያሳየዎት ይችላል።</translation>
<translation id="5546249279042208244">WEB3 DNA Browserን በማስጀመር ላይ...</translation>
<translation id="5255237181758616742">ተለይቶ ባልታወቀ ስህተት ምክንያት ጭነት ከሽፏል። እባክዎ WEB3 DNA Browserን እንደገና ያውርዱ።</translation>
<translation id="8697124171261953979">እንዲሁም WEB3 DNA Browserን ሲጀምሩት ወይም ከኦምኒቦክሱ ሆነው ሲፈልጉ የሚታየውን ገጽ ይቆጣጠራል።</translation>
<translation id="4220559821674570264">ይሄ የእርስዎ WEB3 DNA Browser ነው</translation>
<translation id="8072998028605263569">ሁሉንም የWEB3 DNA Browser መስኮቶች ሲዘጉ፣ ኩኪዎች እና የጣቢያ ውሂብ በራስሰር ይጸዳሉ</translation>
<translation id="6903751245620697304">WEB3 DNA Browserን ሲዘጉ <ph name="BEGIN_BOLD" />ከብዙ ጣቢያዎች ዘግተው እንዲወጡ<ph name="END_BOLD" /> ይደረጋሉ። ማስመር ጠፍቶ ከሆነ <ph name="BEGIN_BOLD" />ከGoogle አገልግሎቶች እና WEB3 DNA Browser<ph name="END_BOLD" /> ዘግተው እንዲወጡ ይደረጋሉ።</translation>
<translation id="7277260025828649281">WEB3 DNA Browser ለዚህ ጣቢያ የእርስዎን ካሜራ እና ማይክሮፎን ለመድረስ ፈቃድ ያስፈልገዋል</translation>
<translation id="8833697763442816810">የChromiumOS ስርዓት</translation>
<translation id="7404934872971073925"><ph name="BEGIN_BOLD" />ምን ውሂብ ጥቅም ላይ እንደሚውል፦<ph name="END_BOLD" /> የአሰሳ ታሪክዎ፣ በዚህ መሣሪያ ላይ WEB3 DNA Browserን ተጠቅመው የጎበኟቸው የጣቢያዎች መዝገብ።</translation>
<translation id="8862326446509486874">ለስርዓተ-ደረጃ ጭነት ተገቢ መብቶች የሉዎትም። ጫኚውን እንደ አስተዳዳሪ በማሄድ እንደገና ይሞክሩ።</translation>
<translation id="8304007095757244531">እንደዚያ ከሆነ፣ ከእርስዎ አዲሱ የይለፍ ቃል ጋር እንዲዛመድ የእርስዎን በWEB3 DNA Browser የተቀመጠ የይለፍ ቃል አርትዕ ያድርጉ።</translation>
<translation id="8897323336392112261">እንዲሁም WEB3 DNA Browserን ሲጀምሩት ወይም የመነሻ አዝራሩን ጠቅ ሲያደርጉት የሚታየውን ገጽ ይቆጣጠራል።</translation>
<translation id="257978004891740263">WEB3 DNA Browser የይለፍ ቃሎችን ለማሳየት እየሞከረ ነው። ይህንን ለመፍቀድ የWindows የይለፍ ቃልዎን ይተይቡ።</translation>
<translation id="7500894618301979366">WEB3 DNA Browser ካለፉት ጥቂት ሳምንታት የአሰሳ ታሪክዎ ላይ በመመስረት ዝንባሌዎችዎን ሊገምት ይችላል። ይህ መረጃ በመሣሪያዎ ላይ ይቆያል።</translation>
<translation id="3731673200617615844">WEB3 DNA Browserን ማዘመን አልተቻለም</translation>
<translation id="1787382483918628946">የWEB3 DNA Browser Enterprise ዓርማ</translation>
<translation id="8986207147630327271">የስራ መገለጫን ወደዚህ አሳሽ እያከሉ እና ለአስተዳዳሪዎ በስራ መገለጫው ላይ ብቻ ቁጥጥር እየሰጡ ነው።</translation>
<translation id="8867249455463470821">WEB3 DNA Browserን ይበልጥ ደህንነቱ የተጠበቀ እንዲሆን ለማድረግ፣ በ<ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> ውስጥ ያልተዘረዘረውን የሚከተለውን ቅጥያ አሰናክለነዋል እና እርስዎ ሳያውቁት የታከለ ሊሆን ይችላል።</translation>
<translation id="8879833215600767638">WEB3 DNA Browser ውስጥ ይግቡ</translation>
<translation id="853293422536067733">WEB3 DNA Browser ጊዜው አልፎበታል</translation>
<translation id="325086175188777548">{0,plural, =1{WEB3 DNA Browser በአንድ ሰዓት ውስጥ ዳግም ይጀምራል}one{WEB3 DNA Browser በ# ሰዓቶች ውስጥ ዳግም ይጀምራል}other{WEB3 DNA Browser በ# ሰዓቶች ውስጥ ዳግም ይጀምራል}}</translation>
<translation id="8024211601023847048">የወደፊት የWEB3 DNA Browser ዝማኔዎችን ለማግኘት Windows 10 ወይም ከዚያ በላይ ያስፈልግዎታል። ይህ ኮምፒውተር Windows 8.1ን እየተጠቀመ ነው።</translation>
<translation id="2383920618768832592">አገናኙን በWEB3 DNA Browser አዲስ &amp;ትር ውስጥ ክፈት</translation>
<translation id="911206726377975832">የአሰሳ ውሂብዎም ይሰረዝ?</translation>
<translation id="3209098675401285328">በሙከራዎቹ ጊዜ ማስታወቂያዎችን ለእርስዎ ለማሳየት የሚጠቀሙባቸውን የዝንባሌ ጣቢያዎች ርዕሶች ማየት እና ማስወገድ ይችላሉ። WEB3 DNA Browser በቅርብ ጊዜ የአሰሳ ታሪክዎ ላይ ተመስርቶ የእርስዎን ፍላጎቶች ይገምታል።</translation>
<translation id="3219820530884298089">የእርስዎ የስርዓት አስተዳዳሪ <ph name="TARGET_URL_HOSTNAME" />ን ለመድረስ WEB3 DNA Browser ተለዋጭ አሳሽን እንዲከፍት አዋቅረውታል።</translation>
<translation id="3490070383213151269">&amp;WEB3 DNA Browserን ለማዘመን ዳግም ያስነሱት</translation>
<translation id="6090927689465861839">WEB3 DNA Browser (mDNS-In)</translation>
<translation id="5838682317838879726">WEB3 DNA Browser በWindows XP ወይም Windows Vista ላይ ከእንግዲህ ስለማይደገፍ በአግባቡ ላይሰራ ይችላል</translation>
<translation id="864578822176559036">በWEB3 DNA Browser የሚተዳደሩ የእውቅና ማረጋገጫዎች</translation>
<translation id="5999581564161388420">የወደፊቱን የWEB3 DNA Browser ዝመኔዎችን ለማግኘት፣ macOS 10.13 ወይም ከዚያ በኋላ ያለው ያስፈልግዎታል። ይህ ኮምፒተር OS X 10.11 እየተጠቀመ ነው።</translation>
<translation id="8170259981824726476">ማነው WEB3 DNA Browserን የሚጠቀመው?</translation>
<translation id="848072905736697318">የWEB3 DNA Browserን ጠንካራ ደህንነት ያግኙ</translation>
<translation id="3707690415152488007">የWEB3 DNA Browser ደራሲዎች</translation>
</translationbundle>