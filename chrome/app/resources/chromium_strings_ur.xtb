<translation id="3829194378861761606">‏آپ کے والدین نے "WEB3 DNA Browser کی خاطر سائٹس، ایپس اور ایکسٹینشنز کے لیے اجازتوں" کو آف کر دیا ہے۔ اس <ph name="EXTENSION_TYPE_PARAMETER" /> کو شامل کرنے کی اجازت نہیں ہے۔</translation>
<translation id="6148620910029690666">‏مستقبل میں WEB3 DNA Browser اپ ڈیٹس حاصل کرنے کے لیے آپ کو macOS 10.13 یا اس کے بعد کے ورژن کی ضرورت ہوگی۔ یہ کمپیوٹر macOS 10.12 کا استعمال کر رہا ہے۔</translation>
<translation id="1246723111619277441">‏جب آپ اپنے Google اکاؤنٹ سے سائن ان کرتے ہیں تو WEB3 DNA Browser آپ کے پاس ورڈز کو چیک کر سکتا ہے</translation>
<translation id="7115352036028984404">‏آن ہونے پر، WEB3 DNA Browser پس منظر کی سرگرمی اور ویژوئل اثرات، جیسے ہموار اسکرولنگ اور ویڈیو فریم ریٹس کو محدود کر کے بیٹری پاور کو محفوظ کرتا ہے۔ <ph name="BEGIN_LINK" />مزید جانیں<ph name="END_LINK" /></translation>
<translation id="4799188800355420938">‏کاپی رائٹ ‎<ph name="YEAR" /> Blockchain Witnesses organization۔ جملہ حقوق محفوظ۔</translation>
<translation id="1392803118131207008">‏<ph name="BEGIN_BOLD" />ہمارا اس ڈیٹا کو استعمال کرنے کا طریقہ:<ph name="END_BOLD" /> سائٹس WEB3 DNA Browser کے ساتھ آپ کی دلچسپیوں کے بارے میں معلومات اسٹور کر سکتی ہیں۔ مثلاً اگر آپ میراتھن کے لئے جوتے خریدنے کی خاطر کوئی سائٹ ملاحظہ کرتے ہیں تو سائٹ دوڑ کے میراتھنز کے بطور آپ کی دلچسپی کا تعین کر سکتی ہے۔ بعد میں اگر آپ دوڑ میں رجسٹر کرنے کے لئے کوئی دوسری سائٹ ملاحظہ کرتے ہیں تو وہ سائٹ آپ کو آپ کی دلچسپیوں کی بنیاد پر دوڑنے کے جوتوں کا اشتہار دکھا سکتی ہے۔</translation>
<translation id="5546249279042208244">‏WEB3 DNA Browser شروع ہو رہا ہے…</translation>
<translation id="5255237181758616742">‏غیر متعین خرابی کی وجہ سے انسٹالیشن ناکام ہوگیا۔ براہ کرم WEB3 DNA Browser دوبارہ ڈاؤن لوڈ کریں۔</translation>
<translation id="8697124171261953979">‏یہ آپ کی جانب سے WEB3 DNA Browser شروع کیے جانے یا اومنی باکس سے تلاش کیے جانے پر دکھائی دینے والے صفحہ کو کنٹرول بھی کرتا ہے۔</translation>
<translation id="4220559821674570264">‏یہ آپ کا WEB3 DNA Browser ہے</translation>
<translation id="8072998028605263569">‏جب آپ سبھی WEB3 DNA Browser ونڈوز بند کرتے ہیں تو کوکیز اور سائٹ کے ڈیٹا خودکار طور پر صاف ہو جاتے ہیں</translation>
<translation id="6903751245620697304">‏آپ کے WEB3 DNA Browser کو بند کرنے پر، آپ کو <ph name="BEGIN_BOLD" />بیشتر سائٹس سے سائن آؤٹ<ph name="END_BOLD" /> کر دیا جائے گا۔ 'سِنک کرنا' آف ہونے پر، آپ کو <ph name="BEGIN_BOLD" />Google سروسز اور WEB3 DNA Browser سے بھی سائن آؤٹ<ph name="END_BOLD" /> کر دیا جائے گا۔</translation>
<translation id="7277260025828649281">‏WEB3 DNA Browser کو اس سائٹ کیلئے آپ کے کیمرے اور مائیکروفون تک رسائی کی اجازت درکار ہے</translation>
<translation id="8833697763442816810">‏ChromiumOS سسٹم</translation>
<translation id="7404934872971073925">‏<ph name="BEGIN_BOLD" />کون سا ڈیٹا استعمال کیا جاتا ہے:<ph name="END_BOLD" /> آپ کی براؤزنگ کی سرگزشت، ان سائٹس کا ریکارڈ جو آپ اس آلے پر WEB3 DNA Browser کا استعمال کر کے ملاحظہ کر چکے ہیں۔</translation>
<translation id="8862326446509486874">سسٹم کی سطح پر انسٹال کرنے کیلئے آپ کے پاس مناسب حقوق نہیں ہیں۔ انسٹالر کو دوبارہ منتظم کے بطور چلانے کی کوشش کریں۔</translation>
<translation id="8304007095757244531">‏اگر ایسا ہے تو براہ کرم WEB3 DNA Browser میں اپنے محفوظ کردہ پاس ورڈ میں ترمیم کریں تاکہ یہ آپ کے نئے پاس ورڈ سے مماثل ہو جائے۔</translation>
<translation id="8897323336392112261">‏یہ آپ کی جانب سے WEB3 DNA Browser شروع کرنے یا ہوم بٹن کلک کرنے پر دکھائی دینے والے صفحہ کو بھی کنٹرول کرتا ہے۔</translation>
<translation id="257978004891740263">‏WEB3 DNA Browser پاس ورڈز دکھانے کی کوشش کر رہا ہے۔ اس کی اجازت دینے کیلئے اپنا Windows کا پاس ورڈ ٹائپ کریں۔</translation>
<translation id="7500894618301979366">‏WEB3 DNA Browser گزشتہ کچھ ہفتوں کی آپ کی براؤزنگ کی سرگزشت کی بنیاد پر آپ کی دلچسپیوں کا اندازہ لگا سکتا ہے۔ یہ معلومات آپ کے آلے پر برقرار رہتی ہے۔</translation>
