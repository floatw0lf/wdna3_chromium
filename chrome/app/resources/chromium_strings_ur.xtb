<translation id="4863557335992202213">‏WEB3 DNA Browser آپ کے پاس ورڈز چیک نہیں کر سکتا کیونکہ آپ سائن ان نہیں ہیں</translation>
<translation id="8332908002682218419">‏WEB3 DNA Browser پاس ورڈز کاپی کرنے کی کوشش کر رہا ہے۔</translation>
<translation id="3862328687893385239">‏یہ فائل خطرناک ہو سکتی ہے، اس لیے WEB3 DNA Browser نے اسے مسدود کر دیا ہے۔</translation>
<translation id="7450630974943556627">‏اپنے آلات پر WEB3 DNA Browser کو مطابقت پذیر اور ذاتی نوعیت کا بنانے کے لیے سائن ان کریں</translation>
<translation id="8910359951607649198">‏<ph name="USER_EMAIL_ADDRESS" /> پہلے WEB3 DNA Browser کا استعمال کر رہا تھا</translation>
<translation id="7837286795552251352">‏اپنے تمام آلات پر اپنے WEB3 DNA Browser براؤزر کی چیزوں تک رسائی حاصل کرنے کیلئے، سائن ان کریں اور پھر مطابقت پذیری کو آن کریں</translation>
<translation id="4231941262737361466">‏مستقبل کے WEB3 DNA Browser اپ ڈیٹس حاصل کرنے کے لیے، آپ کو Windows 10 یا اس کے بعد کے ورژن کی ضرورت ہوگی۔ یہ کمپیوٹر Windows 8 استعمال کر رہا ہے۔</translation>
