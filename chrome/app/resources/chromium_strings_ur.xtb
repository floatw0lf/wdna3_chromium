<translation id="1702866421814791137">‏WEB3 DNA Browser میں موجود Google اسسٹنٹ سبھی ویب سائٹس پر آپ کے لیے کارروائیوں کو مکمل کر سکتی ہے</translation>
<translation id="5618636199529337261">‏آپ کی رازداری کے تحفظ کے لئے، ہم 4 ہفتے سے زیادہ پرانی آپ کی دلچسپیوں کو خودکار طور پر حذف کر دیتے ہیں۔ جب تک آپ براؤزنگ جاری رکھتے ہیں، فہرست پر دلچسپی دوبارہ ظاہر ہو سکتی ہے۔ یا آپ ان دلچسپیوں کو ہٹا سکتے ہیں جنہیں آپ چاہتے ہیں کہ WEB3 DNA Browser نہ دکھائے۔</translation>
<translation id="319672769194370808">‏آپ کی براؤزنگ کی سرگزشت، ان سائٹس کا ریکارڈ جو آپ اس آلے پر WEB3 DNA Browser کا استعمال کر کے ملاحظہ کر چکے ہیں۔</translation>
<translation id="4060507003609322665">‏آپ کے کمپیوٹر میں نقصان دہ سافٹ ویئر ہے۔ WEB3 DNA Browser اسے ہٹا کر آپ کی ترتیبات بحال اور ایکسٹینشنز کو غیر فعال کر سکتا ہے تاکہ آپ کا براؤزر دوبارہ حسب معمول کام کر سکے۔</translation>
