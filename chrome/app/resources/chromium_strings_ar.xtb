<translation id="2422729508884289622">‏يستخدم WEB3 DNA Browser الكاميرا والميكروفون.</translation>
<translation id="7649176261008984828">‏WEB3 DNA Browser أصبح أفضل</translation>
<translation id="7649070708921625228">مساعدة</translation>
<translation id="5663191066657660868">‏يمكنك الاطّلاع على المزيد من المعلومات عن هذه الميزات في إعدادات WEB3 DNA Browser.</translation>
<translation id="1180711544607099420">‏يعمل WEB3 DNA Browser على استكشاف ميزات جديدة تتيح للمواقع الإلكترونية توفير تجربة التصفّح نفسها باستخدام قدر أقل من البيانات.</translation>
<translation id="1427927054102592884">‏WEB3 DNA Browser ليس متصفحك التلقائي.</translation>
<translation id="7195845268083706212">‏يمكنك مزامنة WEB3 DNA Browser وتخصيصه على جميع أجهزتك.</translation>
<translation id="4540014860380760179">‏سيؤدي هذا إلى حذف بيانات التصفح من هذا الجهاز. لاسترداد بياناتك لاحقًا، سجّل الدخول إلى WEB3 DNA Browser كـ <ph name="USER_EMAIL" />.</translation>
<translation id="7747138024166251722">تعذر على أداة المثبِّت إنشاء دليل مؤقت. يُرجى التحقق من وجود مساحة خالية على القرص وتوفر الإذن اللازم لتثبيت البرنامج.</translation>
<translation id="3341158123816213810">‏زيادة سرعة متصفِّح WEB3 DNA Browser</translation>
<translation id="6564515530956462009"><ph name="PAGE_TITLE" /> - WEB3 DNA Browser Canary</translation>
<translation id="8502268940781535829">‏يتوفّر حاليًا على هذا الجهاز ملف شخصي لهذا الحساب على WEB3 DNA Browser.</translation>
<translation id="7845233973568007926">شكرًا على التثبيت. عليك إعادة تشغيل الكمبيوتر قبل استخدام <ph name="BUNDLE_NAME" />.</translation>
<translation id="5422417406245013307">‏تعذّرت إعادة التحميل WEB3 DNA Browser إلى آخر إصدار، لذلك قد تفوتك الميزات الجديدة وعمليات إصلاح الأمان.</translation>
<translation id="7872446069773932638">جارٍ التنزيل… الثواني المتبقّية: <ph name="SECONDS" /></translation>
<translation id="6590823489474620893">‏<ph name="BEGIN_BOLD" />كيفية إدارة بياناتك:<ph name="END_BOLD" /> لحماية خصوصيتك، نحذف تلقائيًا اهتماماتك التي يمر عليها أكثر من أربعة أسابيع. وفي حال بحثت عن أحد الاهتمامات مرّة آخرى، سيظهر في القائمة من جديد. يمكنك إزالة الاهتمامات التي لا تريد أن يضيفها WEB3 DNA Browser إلى قائمة اهتماماتك.</translation>
<translation id="7280500878215405781">‏تم تسجيل دخولك إلى WEB3 DNA Browser باعتبارك <ph name="USER_EMAIL_ADDRESS" />. يُرجى استخدام الحساب نفسه لتسجيل الدخول مرة أخرى.</translation>
<translation id="2253021454574730566">‏هذا تثبيت ثانوي من WEB3 DNA Browser، ولا يمكن جعله متصفحك التلقائي.</translation>
<translation id="2180063386451170761">‏إنّ الإضافات والتطبيقات والمظاهر الواردة من مصادر غير معروفة يمكن أن تتسبّب في إلحاق الضرر بجهازك. ينصح WEB3 DNA Browser بإجراء عملية التثبيت من خلال <ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> فقط.</translation>
<translation id="1446133009793910887">‏بعد حصول WEB3 DNA Browser على إمكانية الوصول، ستتمكن المواقع الإلكترونية من مطالبتك بإمكانية الوصول.</translation>
<translation id="80471789339884597">شكرًا على التثبيت. عليك إعادة تشغيل جميع المتصفِّحات قبل استخدام <ph name="BUNDLE_NAME" />.</translation>
<translation id="3869525261991846539">‏يحتاج WEB3 DNA Browser إلى إذن تحديد الموقع الجغرافي من أجل هذا الموقع الإلكتروني.</translation>
<translation id="8133124826068723441">‏تعذّر على نظام التشغيل WEB3 DNA Browser مزامنة بياناتك لأن المزامنة غير متاحة لنطاقك.</translation>
<translation id="813913629614996137">تجري التهيئة...</translation>
<translation id="6871375725780252705">‏هذا الملف ضار، لذلك فقد حظره WEB3 DNA Browser.</translation>
<translation id="8821717781402291672">‏حَظَر WEB3 DNA Browser هذا الملف لأنّه ملف خطير.</translation>
<translation id="8394136310056741303">‏في حال لم تتضمن صورة ما وصفًا مفيدًا، سيحاول WEB3 DNA Browser توفير وصف لك. لإنشاء الأوصاف، سيتم إرسال الصور إلى Google. ويمكنك إيقاف هذه الميزة في الإعدادات في أي وقت.</translation>
<translation id="4863557335992202213">‏يتعذّر على WEB3 DNA Browser التحقّق من كلمات المرور لأنك لم تسجّل الدخول.</translation>
<translation id="8332908002682218419">‏يحاول WEB3 DNA Browser نسخ كلمات المرور.</translation>
<translation id="3862328687893385239">‏قد يكون هذا الملف ضارًا، لذلك فقد حظره WEB3 DNA Browser.</translation>
<translation id="7450630974943556627">‏يمكنك تسجيل الدخول لمزامنة WEB3 DNA Browser وتخصيصه على جميع أجهزتك.</translation>
<translation id="8910359951607649198">‏كان <ph name="USER_EMAIL_ADDRESS" /> يستخدم WEB3 DNA Browser مسبقًا</translation>
<translation id="7837286795552251352">‏للوصول إلى بياناتك في متصفّح WEB3 DNA Browser من جميع أجهزتك، سجِّل الدخول وفعِّل المزامنة.</translation>
<translation id="4231941262737361466">‏للحصول على تحديثات WEB3 DNA Browser في المستقبل، يجب استخدام كمبيوتر يعمل بنظام التشغيل Windows 10 أو إصدار أحدث. يعمل هذا الكمبيوتر بنظام التشغيل Windows 8.</translation>
<translation id="4708615805477131870">{0,plural, =1{‏يجب إعادة تشغيل WEB3 DNA Browser في غضون يوم واحد}zero{‏يجب إعادة تشغيل WEB3 DNA Browser في غضون # يوم}two{‏يجب إعادة تشغيل WEB3 DNA Browser في غضون يومين}few{‏يجب إعادة تشغيل WEB3 DNA Browser في غضون # أيام}many{‏يجب إعادة تشغيل WEB3 DNA Browser في غضون # يومًا}other{‏يجب إعادة تشغيل WEB3 DNA Browser في غضون # يوم}}</translation>
<translation id="8293407095466346653">‏أرشيف أداة التثبيت تالف أو غير صالح. يُرجى إعادة تنزيل WEB3 DNA Browser.</translation>
<translation id="8463672209299734063">‏إجراء اختياري: يمكنك المساعدة في تحسين ميزات نظام التشغيل WEB3 DNA Browser وأدائه من خلال إرسال بيانات التشخيص والاستخدام تلقائيًا إلى Google.</translation>
<translation id="2275026549113043779">‏إصدار WEB3 DNA Browser قديم</translation>
<translation id="8550334526674375523">هذا الملف الشخصي للعمل منفصِل تمامًا عن ملفك الشخصي.</translation>
<translation id="3829194378861761606">‏أوقفَ أحد والدَيك "أذونات المواقع الإلكترونية والتطبيقات والإضافات" لمتصفِّح WEB3 DNA Browser. ولا يمكن تثبيت <ph name="EXTENSION_TYPE_PARAMETER" />.</translation>
<translation id="6148620910029690666">‏للحصول على تحديثات WEB3 DNA Browser في المستقبل، يجب استخدام جهاز يعمل بنظام التشغيل macOS 10.13 أو إصدار أحدث. يعمل هذا الكمبيوتر بنظام التشغيل macOS 10.12.</translation>
<translation id="1246723111619277441">‏لا يستطيع WEB3 DNA Browser التحقّق من كلمات المرور إلا عند تسجيل الدخول باستخدام حسابك على Google.</translation>
<translation id="7115352036028984404">‏عندما يكون هذا الإعداد مفعَّلاً، يحافظ WEB3 DNA Browser على طاقة البطارية من خلال الحدّ من الأنشطة في الخلفية والتأثيرات المرئية، مثل التمرير السلس وعدد اللقطات في الثانية للفيديو. <ph name="BEGIN_LINK" />مزيد من المعلومات<ph name="END_LINK" /></translation>
<translation id="4799188800355420938">‏حقوق الطبع والنشر لعام <ph name="YEAR" /> لصالح Blockchain Witnesses organization. جميع الحقوق محفوظة.</translation>
<translation id="1392803118131207008">‏<ph name="BEGIN_BOLD" />آلية استخدامنا لهذه البيانات:<ph name="END_BOLD" /> يمكن أن تخزّن المواقع الإلكترونية معلومات عن اهتماماتك في متصفّح WEB3 DNA Browser. على سبيل المثال، إذا انتقلت إلى موقع إلكتروني لشراء حذاء لاستخدامه في سباق ماراثون، قد يحدّد هذا الموقع الإلكتروني حسب تقديره أنك مهتم بسباقات الماراثون. وبعد ذلك، إذا انتقلت إلى موقع إلكتروني آخر للتسجيل في سباق ماراثون، يمكن أن يعرض لك هذا الموقع الإلكتروني إعلانًا عن الأحذية المخصّصة للجري بناءً على اهتماماتك.</translation>
<translation id="5546249279042208244">‏جارٍ إطلاق WEB3 DNA Browser...</translation>
<translation id="5255237181758616742">‏تعذّر التثبيت نظرًا لحدوث خطأ غير محدد. يُرجى إعادة تنزيل WEB3 DNA Browser.</translation>
<translation id="8697124171261953979">‏كما أنها تتحكم في الصفحة التي تظهر عند تشغيل WEB3 DNA Browser أو إجراء بحث من المربع متعدد الاستخدامات.</translation>
<translation id="4220559821674570264">‏هذا هو WEB3 DNA Browser الخاص بك</translation>
<translation id="8072998028605263569">‏عند إغلاق جميع نوافذ WEB3 DNA Browser، يتم تلقائيًا محو ملفات تعريف الارتباط وبيانات المواقع الإلكترونية.</translation>
<translation id="6903751245620697304">‏سيتم <ph name="BEGIN_BOLD" />تسجيل خروجك من معظم المواقع الإلكترونية<ph name="END_BOLD" /> عند إغلاق متصفّح WEB3 DNA Browser. إذا كانت المزامنة متوقّفة، سيتم أيضًا <ph name="BEGIN_BOLD" />تسجيل خروجك من خدمات Google ومتصفّح WEB3 DNA Browser<ph name="END_BOLD" />.</translation>
<translation id="7277260025828649281">‏يحتاج WEB3 DNA Browser إلى إذن للوصول إلى الكاميرا والميكروفون من أجل الموقع الإلكتروني هذا.</translation>
<translation id="8833697763442816810">‏نظام التشغيل WEB3 DNA Browser</translation>
<translation id="7404934872971073925">‏<ph name="BEGIN_BOLD" />البيانات المستخدَمة:<ph name="END_BOLD" /> سجلّ تصفّحك، وهو سجل يشمل المواقع الإلكترونية التي زرتها باستخدام WEB3 DNA Browser على هذا الجهاز.</translation>
<translation id="8862326446509486874">لا تملك الحقوق الكافية للتثبيت على مستوى النظام. جرّب تشغيل المثبِّت بصفة مشرف.</translation>
<translation id="8304007095757244531">‏في هذه الحالة، يُرجى تعديل كلمة المرور المحفوظة في WEB3 DNA Browser لتتطابق مع كلمة المرور الجديدة.</translation>
<translation id="8897323336392112261">‏كما أنها تتحكم في الصفحة التي تظهر عند تشغيل WEB3 DNA Browser أو النقر على زر الصفحة الرئيسية.</translation>
<translation id="257978004891740263">‏يحاول WEB3 DNA Browser عرض كلمات المرور. اكتب كلمة مرور Windows للسماح بذلك.</translation>
<translation id="7500894618301979366">‏يمكن أيضًا أن يقدّر WEB3 DNA Browser اهتماماتك استنادًا إلى سجلّ تصفحّك على مدار الأسابيع القليلة الماضية. ويتم الاحتفاظ بهذه المعلومات على جهازك.</translation>
<translation id="3731673200617615844">‏تعذّرت إعادة التحميل WEB3 DNA Browser</translation>
<translation id="1787382483918628946">‏شعار WEB3 DNA Browser Enterprise</translation>
<translation id="8986207147630327271">أنت على وشك إضافة ملف شخصي للعمل إلى هذا المتصفِّح ومنح المشرف إمكانية التحكُّم في هذا الملف الشخصي للعمل فقط.</translation>
<translation id="8867249455463470821">‏لجعل WEB3 DNA Browser أكثر أمنًا، أوقفنا الإضافة التالية التي لم تُدرج في <ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> وربما تكون قد أضيفت بدون علمك.</translation>
<translation id="8879833215600767638">‏تسجيل الدخول إلى WEB3 DNA Browser</translation>
<translation id="853293422536067733">‏إصدار WEB3 DNA Browser قديم</translation>
<translation id="325086175188777548">{0,plural, =1{‏ستتم إعادة تشغيل WEB3 DNA Browser في غضون ساعة واحدة}zero{‏ستتم إعادة تشغيل WEB3 DNA Browser في غضون # ساعة}two{‏ستتم إعادة تشغيل WEB3 DNA Browser في غضون ساعتين}few{‏ستتم إعادة تشغيل WEB3 DNA Browser في غضون # ساعات}many{‏ستتم إعادة تشغيل WEB3 DNA Browser في غضون # ساعةً}other{‏ستتم إعادة تشغيل WEB3 DNA Browser في غضون # ساعة}}</translation>
<translation id="8024211601023847048">‏للحصول على تحديثات WEB3 DNA Browser في المستقبل، يجب استخدام جهاز يعمل بنظام التشغيل Windows 10 أو إصدار أحدث. يعمل هذا الكمبيوتر بنظام التشغيل Windows 8.1.</translation>
<translation id="2383920618768832592">‏فتح الرابط في علامة تبويب جديدة في WEB3 DNA Browser</translation>
<translation id="911206726377975832">هل تريد أيضًا حذف بيانات التصفح؟</translation>
<translation id="3209098675401285328">‏أثناء التجارب، يمكنك الاطِّلاع على المواضيع محل الاهتمام التي استخدمتها المواقع الإلكترونية لعرض الإعلانات لك ويمكنك إزالة هذه المواضيع. ويقدِّر WEB3 DNA Browser اهتماماتك بناءً على سجل التصفّح الأخير.</translation>
<translation id="3219820530884298089">‏ضَبَط مشرف النظام WEB3 DNA Browser لفتح متصفِّح بديل للوصول إلى <ph name="TARGET_URL_HOSTNAME" />.</translation>
<translation id="3490070383213151269">‏إعادة تشغيل متصفِّح WEB3 DNA Browser لتحديثه</translation>
<translation id="6090927689465861839">WEB3 DNA Browser (mDNS-In)</translation>
<translation id="5838682317838879726">‏قد لا يعمل WEB3 DNA Browser بشكل صحيح لأنه لم يعد مدعومًا على أنظمة التشغيل Windows XP أو Windows Vista.</translation>
<translation id="864578822176559036">‏الشهادات التي يديرها متصفّح WEB3 DNA Browser</translation>
<translation id="5999581564161388420">‏للحصول على تحديثات WEB3 DNA Browser في المستقبل، يجب استخدام جهاز يعمل بنظام التشغيل macOS 10.13 أو إصدار أحدث. يعمل هذا الكمبيوتر بنظام التشغيل OS X 10.11.</translation>
