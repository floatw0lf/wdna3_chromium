<translation id="5628570284195611526">‏WEB3 DNA Browser יכול להעריך מהם תחומי העניין שלך. לאחר מכן, אתר שבו ביקרת יכול לשלוח בקשה ל-WEB3 DNA Browser כדי לגלות מהם תחומי העניין שלך ולהתאים אישית את המודעות שמוצגות לך.</translation>
<translation id="7583399374488819119">מנהל ההתקנה של <ph name="COMPANY_NAME" /></translation>
<translation id="18937021822671718">‏הפעלת בחשבון שלך את הגרסה המשופרת של הגלישה הבטוחה. עכשיו אפשר להפעיל אותה ב-WEB3 DNA Browser.</translation>
<translation id="2422729508884289622">‏WEB3 DNA Browser משתמש במצלמה ובמיקרופון שלך.</translation>
<translation id="7649176261008984828">‏WEB3 DNA Browser השתפר</translation>
<translation id="7649070708921625228">עזרה</translation>
<translation id="5663191066657660868">‏מידע נוסף לגבי התכונות האלה זמין בהגדרות של WEB3 DNA Browser.</translation>
<translation id="1180711544607099420">‏אנחנו בודקים תכונות חדשות ב-WEB3 DNA Browser שמאפשרות לאתרים להציג את אותה חוויית הגלישה תוך שימוש בפחות נתונים.</translation>
<translation id="1427927054102592884">‏WEB3 DNA Browser אינו דפדפן ברירת המחדל שלך</translation>
<translation id="7195845268083706212">‏סנכרון והתאמה אישית של WEB3 DNA Browser בכל המכשירים שברשותך</translation>
<translation id="4540014860380760179">‏פעולה זו תמחק את נתוני הגלישה מהמכשיר. כדי לשחזר את הנתונים מאוחר יותר, יש להיכנס אל WEB3 DNA Browser עם <ph name="USER_EMAIL" />.</translation>
<translation id="7747138024166251722">המתקין לא הצליח ליצור ספרייה זמנית. יש לבדוק את המקום הפנוי בדיסק ואת האישור להתקנת תוכנה.</translation>
<translation id="3341158123816213810">‏שיפור המהירות ב-WEB3 DNA Browser</translation>
<translation id="6564515530956462009">‏<ph name="PAGE_TITLE" /> – WEB3 DNA Browser בגרסת Canary</translation>
<translation id="8502268940781535829">‏כבר קיים במכשיר פרופיל WEB3 DNA Browser עם החשבון הזה.</translation>
<translation id="7845233973568007926">תודה שהתקנת. עליך להפעיל מחדש את המחשב לפני השימוש ב-<ph name="BUNDLE_NAME" />.</translation>
<translation id="5422417406245013307">‏עדכון WEB3 DNA Browser לגרסה האחרונה לא הצליח, ולכן אין לך גישה אל תכונות חדשות ותיקוני אבטחה.</translation>
<translation id="7872446069773932638">מתבצעת הורדה… יש עוד <ph name="SECONDS" /> שנ'</translation>
<translation id="6590823489474620893">‏<ph name="BEGIN_BOLD" />איך ניתן לנהל את הנתונים שלך:<ph name="END_BOLD" /> כדי להגן על הפרטיות שלך, תחומי עניין שהוגדרו לפני יותר מ-4 שבועות נמחקים אוטומטית. עם המשך הגלישה, תחום עניין כלשהו עשוי להופיע שוב ברשימה. יש גם אפשרות להסיר תחומי עניין מ-WEB3 DNA Browser כדי שלא יילקחו בחשבון.</translation>
<translation id="7280500878215405781">‏נכנסת ל-WEB3 DNA Browser כ-<ph name="USER_EMAIL_ADDRESS" />. יש להשתמש באותו חשבון כדי להיכנס שוב.</translation>
<translation id="2253021454574730566">‏זוהי התקנה משנית של WEB3 DNA Browser, ולא ניתן להפוך אותו לדפדפן ברירת המחדל שלך.</translation>
<translation id="2180063386451170761">‏תוספים, אפליקציות ועיצובים ממקורות לא מוכרים עלולים להזיק למכשיר. ההמלצה של WEB3 DNA Browser היא להתקין אותם רק מ<ph name="IDS_EXTENSION_WEB_STORE_TITLE" /></translation>
<translation id="1446133009793910887">‏אחרי מתן גישה ל-WEB3 DNA Browser, אתרים יוכלו לבקש ממך גישה.</translation>
<translation id="80471789339884597">תודה שהתקנת. עליך להפעיל מחדש את כל הדפדפנים לפני השימוש ב-<ph name="BUNDLE_NAME" />.</translation>
<translation id="3869525261991846539">‏נדרשת הרשאת מיקום ב-WEB3 DNA Browser עבור האתר הזה</translation>
<translation id="8133124826068723441">‏לא בוצע סנכרון של הנתונים ב-ChromiumOS כי אפשרות הסנכרון לא זמינה עבור הדומיין שלך.</translation>
<translation id="813913629614996137">מתבצע אתחול...</translation>
<translation id="6871375725780252705">‏WEB3 DNA Browser‏ חסם את הקובץ הזה כי הוא מסוכן.</translation>
<translation id="8821717781402291672">‏סוג הקובץ הזה מסוכן ולכן הקובץ נחסם על ידי WEB3 DNA Browser</translation>
<translation id="8394136310056741303">‏אם אין לתמונה תיאור מועיל, WEB3 DNA Browser ינסה לספק לך תיאור. כדי ליצור תיאורים, התמונות נשלחות אל Google. אפשר להשבית את האפשרות הזו בכל זמן דרך ההגדרות.</translation>
<translation id="4863557335992202213">‏WEB3 DNA Browser לא יכול לבדוק את הסיסמאות שלך כי לא נכנסת לחשבון</translation>
<translation id="8332908002682218419">‏WEB3 DNA Browser מנסה להעתיק את הסיסמאות.</translation>
<translation id="3862328687893385239">‏WEB3 DNA Browser‏ חסם את הקובץ הזה כי הוא עלול להיות מסוכן.</translation>
<translation id="7450630974943556627">‏כניסה לחשבון תסנכרן ותתאים אישית את WEB3 DNA Browser בכל המכשירים שברשותך</translation>
<translation id="8910359951607649198">‏בכתובת <ph name="USER_EMAIL_ADDRESS" /> השתמשו בעבר ב-WEB3 DNA Browser</translation>
<translation id="7837286795552251352">‏כדי לגשת אל פריטים שונים בדפדפן WEB3 DNA Browser שלך מכל המכשירים, צריך להיכנס לחשבון ולהפעיל את הסנכרון</translation>
<translation id="4231941262737361466">‏כדי לקבל עדכונים של WEB3 DNA Browser בעתיד, צריך להשתמש ב-Windows מגרסה 10 ואילך. במחשב הזה פועלת מערכת Windows 8.</translation>
<translation id="4708615805477131870">{0,plural, =1{‏צריך להפעיל מחדש את WEB3 DNA Browser בתוך יום אחד}two{‏צריך להפעיל מחדש את WEB3 DNA Browser בתוך # ימים}many{‏צריך להפעיל מחדש את WEB3 DNA Browser בתוך # ימים}other{‏צריך להפעיל מחדש את WEB3 DNA Browser בתוך # ימים}}</translation>
<translation id="8293407095466346653">‏הארכיון של המתקין פגום או שאינו חוקי. יש להוריד שוב את WEB3 DNA Browser.</translation>
<translation id="8463672209299734063">‏אופציונלי: שליחה אוטומטית של נתוני אבחון ונתוני שימוש במכשיר אל Google תעזור לשפר את התכונות ואת הביצועים של ChromiumOS.</translation>
<translation id="2275026549113043779">‏WEB3 DNA Browser אינו מעודכן</translation>
<translation id="8550334526674375523">פרופיל העבודה שלך נפרד לחלוטין מהפרופיל האישי שלך.</translation>
<translation id="3829194378861761606">‏אחד מההורים השבית ב-WEB3 DNA Browser את ההגדרה "הרשאות לאתרים, אפליקציות ותוספים". לא ניתן להוסיף את ה<ph name="EXTENSION_TYPE_PARAMETER" />.</translation>
<translation id="6148620910029690666">‏כדי לקבל עדכונים של WEB3 DNA Browser בעתיד, צריך להשתמש ב-macOS מגרסה 10.13 ואילך. במחשב הזה מותקנת מערכת ההפעלה macOS 10.12.</translation>
<translation id="1246723111619277441">‏WEB3 DNA Browser יכול לבדוק את הסיסמאות כשנכנסים באמצעות חשבון Google</translation>
<translation id="7115352036028984404">‏כשהתכונה מופעלת, WEB3 DNA Browser חוסך בחיי הסוללה על ידי הגבלת הפעילות ברקע והאפקטים החזותיים, כמו גלילה חלקה וקצב פריימים של סרטונים. <ph name="BEGIN_LINK" />מידע נוסף<ph name="END_LINK" /></translation>
<translation id="4799188800355420938">‏Copyright <ph name="YEAR" /> Blockchain Witnesses organization. כל הזכויות שמורות.</translation>
<translation id="1392803118131207008">‏<ph name="BEGIN_BOLD" />אופן השימוש בנתונים האלה:<ph name="END_BOLD" /> אתרים יכולים לשמור מידע ב-WEB3 DNA Browser לגבי תחומי העניין שלך. לדוגמה, אם ביקרת באתר כדי לקנות נעליים למרתון, האתר עשוי להגדיר 'ריצת מרתון' כתחום עניין שלך. לאחר מכן, בביקור באתר שונה, למשל כדי להירשם למרוץ, יכול להיות שתוצג לך מודעה לנעלי ריצה על סמך תחומי העניין שלך.</translation>
<translation id="5546249279042208244">‏הפעלת WEB3 DNA Browser מתבצעת...</translation>
<translation id="5255237181758616742">‏ההתקנה נכשלה בשל שגיאה לא מזוהה. יש להוריד שוב את WEB3 DNA Browser.</translation>
<translation id="8697124171261953979">‏הגדרה זו גם קובעת איזה דף מוצג כשמפעילים את WEB3 DNA Browser או מבצעים חיפוש מסרגל הכתובות.</translation>
<translation id="4220559821674570264">‏זהו ה-WEB3 DNA Browser שלך</translation>
<translation id="8072998028605263569">‏אחרי שסוגרים את כל החלונות של WEB3 DNA Browser, קובצי cookie ונתוני אתרים נמחקים אוטומטית</translation>
<translation id="6903751245620697304">‏המערכת <ph name="BEGIN_BOLD" />תוציא אותך מהחשבון ברוב האתרים<ph name="END_BOLD" /> עם סגירת WEB3 DNA Browser. אם הסנכרון כבוי, המערכת <ph name="BEGIN_BOLD" />תוציא אותך מהחשבון גם בשירותי Google וב-WEB3 DNA Browser<ph name="END_BOLD" />.</translation>
<translation id="7277260025828649281">‏WEB3 DNA Browser זקוק להרשאת גישה אל המצלמה והמיקרופון בשביל האתר הזה</translation>
<translation id="8833697763442816810">‏מערכת ChromiumOS</translation>
<translation id="7404934872971073925">‏<ph name="BEGIN_BOLD" />באילו נתונים נעשה שימוש:<ph name="END_BOLD" /> היסטוריית הגלישה – תיעוד האתרים שביקרת בהם באמצעות WEB3 DNA Browser במכשיר הזה.</translation>
<translation id="8862326446509486874">אין לך זכויות שמתאימות להתקנה ברמת המערכת. יש לנסות להפעיל שוב את המתקין כמנהל מערכת.</translation>
<translation id="8304007095757244531">‏אם שינית את הסיסמה הזו, יש לערוך את הסיסמה השמורה ב-WEB3 DNA Browser כך שהיא תתאים לסיסמה החדשה שלך.</translation>
<translation id="8897323336392112261">‏הגדרה זו גם קובעת איזה דף מוצג כשמפעילים את WEB3 DNA Browser או לוחצים על הלחצן 'דף הבית'.</translation>
<translation id="257978004891740263">‏WEB3 DNA Browser מנסה להציג סיסמאות. יש להקליד את הסיסמה שלך ל-Windows כדי לאפשר זאת.</translation>
<translation id="7500894618301979366">‏WEB3 DNA Browser יכול להעריך מהם תחומי העניין שלך על סמך היסטוריית הגלישה שלך מהשבועות האחרונים. המידע הזה נשאר במכשיר שלך.</translation>
<translation id="3731673200617615844">‏לא ניתן לעדכן את WEB3 DNA Browser</translation>
<translation id="1787382483918628946">‏הלוגו של WEB3 DNA Browser Enterprise</translation>
<translation id="8986207147630327271">בחרת להוסיף פרופיל עבודה לדפדפן זה ולתת למנהל המערכת שליטה רק על פרופיל העבודה.</translation>
<translation id="8867249455463470821">‏כדי לשפר את האבטחה של WEB3 DNA Browser, השבתנו את התוסף הבא שאינו רשום ב-<ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> וייתכן שנוסף ללא ידיעתך.</translation>
<translation id="8879833215600767638">‏כניסה אל WEB3 DNA Browser</translation>
<translation id="853293422536067733">‏WEB3 DNA Browser אינו מעודכן</translation>
<translation id="325086175188777548">{0,plural, =1{‏WEB3 DNA Browser יופעל מחדש בעוד שעה}two{‏WEB3 DNA Browser יופעל מחדש בעוד # שעות}many{‏WEB3 DNA Browser יופעל מחדש בעוד # שעות}other{‏WEB3 DNA Browser יופעל מחדש בעוד # שעות}}</translation>
<translation id="8024211601023847048">‏כדי לקבל עדכונים של WEB3 DNA Browser בעתיד, צריך להשתמש ב-Windows מגרסה 10 ואילך. במחשב הזה פועלת מערכת Windows 8.1.</translation>
<translation id="2383920618768832592">‏פתיחת הקישור &amp;בכרטיסיית WEB3 DNA Browser חדשה</translation>
<translation id="911206726377975832">למחוק גם את נתוני הגלישה שלך?</translation>
<translation id="3209098675401285328">‏במהלך הפעולה של גרסאות הניסיון, תהיה לך אפשרות לראות ולהסיר את תחומי העניין שלפיהם האתרים הציגו לך את המודעות. ההערכה של תחומי העניין ב-WEB3 DNA Browser מתבססת על היסטוריית הגלישה שלך מהזמן האחרון.</translation>
<translation id="3219820530884298089">‏לפי הגדרת מנהל המערכת, WEB3 DNA Browser יפתח דפדפן חלופי כדי לגשת אל <ph name="TARGET_URL_HOSTNAME" />.</translation>
<translation id="3490070383213151269">‏הפעלה מחדש לצורך עדכון &amp;WEB3 DNA Browser</translation>
