<!DOCTYPE translationbundle>
<translationbundle lang="iw">
<translation id="1026101648481255140">המשך בהתקנה</translation>
<translation id="1029669172902658969">‏הפעלה מחדש לצורך עדכון ‎&amp;ChromiumOS</translation>
<translation id="1065672644894730302">לא הייתה אפשרות לקרוא את ההעדפות שלך. ייתכן שחלק מהתכונות לא יהיו זמינות ושינויים בהעדפות לא יישמרו.</translation>
<translation id="4960963727707787489">‏WEB3 DNA Browser עוזר להגן עליך מפני פרצות באבטחת המידע, תוספים לא תקינים ועוד</translation>
<translation id="1018420750873862665">‏WEB3 DNA Browser רוצה לייצא את הסיסמאות שלך. יש להקליד את הסיסמה שלך ל-Windows כדי לאפשר זאת.</translation>
<translation id="8728335547814212082">‏WEB3 DNA Browser מוגדר כדפדפן ברירת המחדל</translation>
<translation id="3462550327714525487">‏כדי לבדוק אם שאר הסיסמאות מוגנות מפני פרצות באבטחת מידע ובעיות אבטחה אחרות, <ph name="BEGIN_LINK" />יש להיכנס ל-WEB3 DNA Browser<ph name="END_LINK" />.</translation>
<translation id="4464481789599383598">‏על WEB3 DNA Browser</translation>
<translation id="1203500561924088507">תודה שהתקנת. עליך להפעיל מחדש את הדפדפן לפני השימוש ב-<ph name="BUNDLE_NAME" />.</translation>
<translation id="5978964989109500768">‏כשההגדרה מופעלת, WEB3 DNA Browser מפנה מקום בזיכרון שמוקצה לכרטיסיות לא פעילות. כך, לכרטיסיות הפעילות ולאפליקציות אחרות יש יותר משאבים מהמחשב ו-WEB3 DNA Browser פועל מהר. כשחוזרים לכרטיסיות הלא פעילות, הן מופעלות מחדש באופן אוטומטי. <ph name="BEGIN_LINK" />מידע נוסף<ph name="END_LINK" /></translation>
<translation id="2556820941333974881">‏WEB3 DNA Browser פועל מהר יותר בזכות מצב החיסכון בזיכרון</translation>
<translation id="8674698533637405550">‏הגדרת הפרופיל החדש שלך ב-WEB3 DNA Browser</translation>
<translation id="5897235607289042281">‏Google Assistant ב-WEB3 DNA Browser</translation>
<translation id="4011302926653396528">‏WEB3 DNA Browser מנסה להציג סיסמאות.</translation>
<translation id="7808556894409107558">‏נכנסת ל-WEB3 DNA Browser!</translation>
<translation id="2448956114941459869">‏אפשר ליהנות מהמיטב של WEB3 DNA Browser</translation>
<translation id="6123758632973468022">‏שיתוף כרטיסיית WEB3 DNA Browser</translation>
<translation id="1232307829393891937">‏WEB3 DNA Browser זקוק להרשאת גישה למצלמה כדי ליצור מפה תלת-ממדית של הסביבה שלך</translation>
<translation id="5103307222334991576">{COUNT,plural, =0{‏מנהל המערכת מבקש להפעיל מחדש את WEB3 DNA Browser כדי להחיל עדכון}=1{‏מנהל המערכת מבקש להפעיל מחדש את WEB3 DNA Browser כדי להחיל עדכון. החלון האנונימי לא ייפתח מחדש.}two{‏מנהל המערכת מבקש להפעיל מחדש את WEB3 DNA Browser כדי להחיל עדכון. # החלונות האנונימיים לא ייפתחו מחדש.}many{‏מנהל המערכת מבקש להפעיל מחדש את WEB3 DNA Browser כדי להחיל עדכון. # החלונות האנונימיים לא ייפתחו מחדש.}other{‏מנהל המערכת מבקש להפעיל מחדש את WEB3 DNA Browser כדי להחיל עדכון. # החלונות האנונימיים לא ייפתחו מחדש.}}</translation>
<translation id="7291131704197390431">‏בדיקה של אמצעי הבקרה החשובים ביותר על פרטיות ואבטחה ב-WEB3 DNA Browser</translation>
<translation id="5962221630684419652">‏אם ברצונך להשתמש בחשבון הזה באופן חד-פעמי, אפשר להשתמש <ph name="GUEST_LINK_BEGIN" />במצב אורח<ph name="GUEST_LINK_END" /> בדפדפן WEB3 DNA Browser. כדי להוסיף חשבון של מישהו אחר, <ph name="LINK_BEGIN" />יש להוסיף משתמש חדש<ph name="LINK_END" /> אל <ph name="DEVICE_TYPE" />.

יכול להיות שהרשאות שכבר נתת לאתרים ולאפליקציות יחולו על החשבון הזה. יש לך גם אפשרות לנהל את חשבונות Google <ph name="SETTINGS_LINK_BEGIN" />בהגדרות<ph name="SETTINGS_LINK_END" />.</translation>
<translation id="1640672724030957280">מוריד...</translation>
<translation id="2804101107797787361">‏גרסה חדשה ובטוחה יותר של WEB3 DNA Browser זמינה כעת.</translation>
<translation id="9029405963934901712">‏יש לך אפשרות לראות ולהסיר את תחומי העניין שלפיהם האתרים מציגים לך את המודעות. ההערכה של תחומי העניין ב-WEB3 DNA Browser מתבססת על היסטוריית הגלישה שלך מהזמן האחרון.</translation>
<translation id="2051400772676536118">‏התרה ל-WEB3 DNA Browser לפעול ברקע</translation>
<translation id="9219442880476358008">‏כדי לשפר את האבטחה של WEB3 DNA Browser, השבתנו חלק מהתוספים שלא רשומים ב<ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> וייתכן שנוספו ללא ידיעתך.</translation>
<translation id="2776567154969336836">‏התקנת WEB3 DNA Browser מחדש</translation>
<translation id="4915372523140836376">‏יש לך אפשרות לנהל את חשבונות Google שאליהם נכנסת. כדי ליהנות מחיבור לחשבון בדפדפן WEB3 DNA Browser, בחנות Play, ב-‏Gmail ובשירותים נוספים, עליך להיכנס עם חשבונות Google שלך. כדי להוסיף חשבון של מישהו אחר, כמו חבר/ה בקבוצה המשפחתית, יש להוסיף משתמש חדש ל-<ph name="DEVICE_TYPE" />. <ph name="LINK_BEGIN" />מידע נוסף<ph name="LINK_END" /></translation>
<translation id="4370275707492934729">‏אתרים יכולים לשמור מידע ב-WEB3 DNA Browser לגבי תחומי העניין שלך. לדוגמה, אם ביקרת באתר כדי לקנות נעליים למרתון, האתר עשוי להגדיר 'ריצת מרתון' כתחום עניין שלך. לאחר מכן, בביקור באתר שונה, למשל כדי להירשם למרוץ, יכול להיות שתוצג לך מודעה לנעלי ריצה על סמך תחומי העניין שלך.</translation>
<translation id="4590088122952951314">‏נכנסת עם חשבון מנוהל שנותן למנהל המערכת שלו שליטה על הפרופיל שלך ב-WEB3 DNA Browser. הנתונים שלך ב-WEB3 DNA Browser, כגון אפליקציות, סימניות, היסטוריה, סיסמאות והגדרות אחרות ייקשרו באופן קבוע ל-<ph name="USER_NAME" />. ניתן למחוק את הנתונים האלה באמצעות לוח הבקרה של חשבונות Google, אבל אי אפשר לשייך את הנתונים האלה לחשבון אחר. לחלופין, באפשרותך ליצור פרופיל חדש כדי לשמור את הנתונים הקיימים שלך ב-WEB3 DNA Browser בנפרד.<ph name="LEARN_MORE" /></translation>
<translation id="1773107071029134155">‏כיבוי הגדרה זו יאפשר לך להיכנס לאתרי Google, כמו Gmail, בלי להיכנס אל WEB3 DNA Browser</translation>
<translation id="1404683263809963517">‏WEB3 DNA Browser אינו מגיב. להפעיל מחדש עכשיו?</translation>
<translation id="193439633299369377">‏צריך להפעיל מחדש את ChromiumOS כדי להחיל את העדכון הזה.</translation>
<translation id="2844934533235602125">‏אם ברצונך להשתמש בחשבון הזה באופן חד-פעמי, אפשר להשתמש במצב אורח בדפדפן WEB3 DNA Browser. כדי להוסיף חשבון של מישהו אחר, <ph name="LINK_BEGIN" />יש להוסיף משתמש חדש<ph name="LINK_END" /> אל <ph name="DEVICE_TYPE" />.

יכול להיות שהרשאות שכבר נתת לאתרים ולאפליקציות יחולו על החשבון הזה. יש לך גם אפשרות לנהל את חשבונות Google <ph name="SETTINGS_LINK_BEGIN" />בהגדרות<ph name="SETTINGS_LINK_END" />.</translation>
<translation id="1953553007165777902">מתבצעת הורדה… יש עוד <ph name="MINUTE" /> דק'</translation>
<translation id="7100172292317798034">‏ב-WEB3 DNA Browser לא ניתן לקבוע או להגדיר את דפדפן ברירת המחדל</translation>
<translation id="7388619658790717510">‏הפעולה הזו תמחק פריט אחד מהמכשיר. כדי לשחזר את הנתונים מאוחר יותר, היכנס אל WEB3 DNA Browser עם <ph name="USER_EMAIL" />.</translation>
<translation id="2018879682492276940">ההתקנה נכשלה. יש לנסות שוב.</translation>
<translation id="8775681507105719302">‏כדי לבדוק אם שאר הסיסמאות מוגנות מפני פרצות באבטחת מידע ובעיות אבטחה אחרות, <ph name="BEGIN_LINK" />יש להיכנס ל-WEB3 DNA Browser<ph name="END_LINK" />.</translation>
<translation id="6765354414432698675">‏בוחרים אם לכלול את ההיסטוריה ב-WEB3 DNA Browser להתאמה אישית מדויקת יותר בשירותי Google</translation>
<translation id="5773286839920477494">‏מידע על האופן שבו WEB3 DNA Browser מנהל את אישורי הבסיס שלו</translation>
<translation id="1342703999636762729">‏התאמה אישית של WEB3 DNA Browser</translation>
<translation id="2174917724755363426">ההתקנה לא הושלמה. להמשיך בביטול?</translation>
<translation id="4604256298037443917">‏WEB3 DNA Browser – כניסה לרשת – <ph name="PAGE_TITLE" /></translation>
<translation id="3692764894142598026">‏אם משתפים מחשב, חברים ובני משפחה יכולים לגלוש בנפרד ולהגדיר את WEB3 DNA Browser בדיוק כפי שהם רוצים.</translation>
<translation id="1653667178840181002">‏המערכת בודקת כתובות URL בעזרת רשימה של אתרים לא בטוחים ששמורה ב-WEB3 DNA Browser. אם באתר כלשהו מתבצע ניסיון לגנוב את הסיסמה שלך, או אם המערכת מזהה הורדה של קובץ מזיק, WEB3 DNA Browser עשוי גם לשלוח כתובות URL לבדיקה באמצעות 'גלישה בטוחה'. הנתונים שנשלחים לבדיקה כוללים ביטים מתוכן של דפים.</translation>
<translation id="4170954887813547201">‏כדי לשלוח מספר מכאן לטלפון Android, יש להיכנס ל-WEB3 DNA Browser בשני המכשירים.</translation>
<translation id="7632546848754920458">‏התוסף שינה את הדף שמוצג כשמפעילים את WEB3 DNA Browser.</translation>
<translation id="2359808026110333948">המשך</translation>
<translation id="2384373936468275798">‏לא בוצע סנכרון של הנתונים שלך ב-ChromiumOS כי פרטי הכניסה לחשבון לא מעודכנים.</translation>
<translation id="3766979587851503326">‏התוסף "<ph name="EXTENSION_NAME" />" שינה את הדף שמוצג כשמפעילים את WEB3 DNA Browser.</translation>
<translation id="3197411627422504716">‏נדרשות הרשאות גישה למצלמה ולמיקרופון ב-WEB3 DNA Browser עבור האתר הזה</translation>
<translation id="6895208784707407784">‏ב-WEB3 DNA Browser</translation>
<translation id="2485422356828889247">הסרת התקנה</translation>
<translation id="5049950391929594900">‏WEB3 DNA Browser זקוק לגישה לאחסון כדי להוריד קבצים</translation>
<translation id="2749516262341915024">WEB3 DNA Browser Helper</translation>
<translation id="2113242903075215938">‏המנהל של פרופיל העבודה יכול להסיר נתוני WEB3 DNA Browser שמופקים בזמן השימוש בפרופיל (כמו יצירת סימניות, היסטוריה, סיסמאות והגדרות נוספות). <ph name="LEARN_MORE" /></translation>
<translation id="4952960270884842265">‏המשך השימוש ב-WEB3 DNA Browser</translation>
<translation id="2731252252225464533">‏במהלך ההתקנה ארעה שגיאה של מערכת ההפעלה. יש להוריד שוב את WEB3 DNA Browser.</translation>
<translation id="1821196395946518624">‏אם משתפים מכשיר, חברים ובני משפחה יכולים לגלוש בנפרד ולהגדיר את WEB3 DNA Browser בדיוק כפי שהם רוצים</translation>
<translation id="5872680003660133275">‏קובץ הארכיון הזה נחסם על ידי WEB3 DNA Browser כי הוא עלול להסתיר תוכנה זדונית</translation>
<translation id="7648513030043385007">‏ברוך בואך אל WEB3 DNA Browser, <ph name="ACCOUNT_FIRST_NAME" /></translation>
<translation id="544374351717235856">‏כרטיסייה של WEB3 DNA Browser</translation>
<translation id="5554916945232735698">‏לשיפור האבטחה, WEB3 DNA Browser יצפין את הנתונים.</translation>
<translation id="2770231113462710648">שינוי דפדפן ברירת המחדל ל:</translation>
<translation id="2799223571221894425">הפעלה מחדש</translation>
<translation id="7343868188703540938">‏ייווצר פרופיל WEB3 DNA Browser חדש בשביל <ph name="USER_EMAIL_ADDRESS" />.</translation>
<translation id="4410717336615333062">‏הסרה מ-WEB3 DNA Browser...</translation>
<translation id="4055140529823965372">‏מגינה עליך ב-WEB3 DNA Browser ועשויה לשפר את רמת האבטחה באפליקציות אחרות של Google. ההגנה הזו פעילה רק אם נכנסים לחשבון.</translation>
<translation id="2885378588091291677">מנהל המשימות</translation>
<translation id="224853752763613334">‏מידע על &amp;WEB3 DNA Browser‏</translation>
<translation id="2915996080311180594">הפעלה מחדש מאוחר יותר</translation>
<translation id="2928420929544864228">ההתקנה הושלמה.</translation>
<translation id="8483611164641766271">‏WEB3 DNA Browser‏ מעודכן</translation>
<translation id="2739338544529681223">‏אם באתר כלשהו מתבצע ניסיון לגנוב את הסיסמה שלך, או אם המערכת מזהה הורדה של קובץ מזיק, WEB3 DNA Browser עשוי גם לשלוח כתובות URL לבדיקה באמצעות 'גלישה בטוחה'. הנתונים שנשלחים לבדיקה כוללים ביטים מתוכן של דפים</translation>
<translation id="6709063507223740532">‏WEB3 DNA Browser מנסה לערוך את הסיסמאות.</translation>
<translation id="6416874087185776406">‏WEB3 DNA Browser לא יכול לבדוק את הסיסמאות שלך. כדאי לנסות שוב מאוחר יותר.</translation>
<translation id="7632657090539802919">‏מתבצעת הוספה ל-WEB3 DNA Browser...</translation>
<translation id="3038232873781883849">בהמתנה להתקנה…</translation>
<translation id="8517483409722571699">‏עזרה בשיפור WEB3 DNA Browser על ידי שליחת <ph name="UMA_LINK" /> ודוחות קריסה אל Google</translation>
<translation id="4288053573753081242">‏היסטוריית הגלישה שלך משפיעה על המודעות שמוצגות לך ועל תחומי העניין המשוערים שמופיעים בהמשך. כדי להגן על הפרטיות שלך, מתבצעת ב-WEB3 DNA Browser מחיקה אוטומטית של תחומי העניין שלך על בסיס מתחלף מדי חודש. תחומי עניין שלא הוסרו עוברים רענון.</translation>
<translation id="4786656728645530523">‏המתקין לא הצליח לבטל את דחיסת הארכיון. יש להוריד שוב את WEB3 DNA Browser.</translation>
<translation id="9049602934378376908">‏WEB3 DNA Browser משתמש במיקרופון שלך.</translation>
<translation id="5623271663074009477">‏הפעלה מחדש של WEB3 DNA Browser</translation>
<translation id="8452871758697304895">‏פתיחת הקישור בחלון &amp;אנונימי של WEB3 DNA Browser</translation>
<translation id="1129084746726669073">‏התאמה אישית של פרופיל WEB3 DNA Browser החדש</translation>
<translation id="5492613633683347362">‏וואו! WEB3 DNA Browser קרס. להפעיל מחדש עכשיו?</translation>
<translation id="8199824399077877420">‏WEB3 DNA Browser רוצה לייצא את הסיסמאות שלך.</translation>
<translation id="4228792865955409287">‏WEB3 DNA Browser אינו יכול לקרוא ולכתוב בספריית הנתונים שלו: <ph name="USER_DATA_DIRECTORY" /></translation>
<translation id="3857433786109736615">‏מותקנת גרסה <ph name="PRODUCT_VERSION" /> של WEB3 DNA Browser</translation>
<translation id="3286538390144397061">הפעל מחדש כעת</translation>
<translation id="1496654316150745021">‏המפתחות של Google API חסרים. פונקציונליות מסוימת של WEB3 DNA Browser תהיה מושבתת.</translation>
<translation id="1658920309978171288">‏המשך הפעלת יישומים ברקע כאשר WEB3 DNA Browser סגור</translation>
<translation id="6099044929456210951">‏כבר קיים פרופיל WEB3 DNA Browser עם החשבון הזה</translation>
<translation id="3387527074123400161">ChromiumOS</translation>
