<translation id="3254774751045951355">‏התאמה אישית וניהול של WEB3 DNA Browser נחוצה פעולה שלך - יש ללחוץ לקבלת פרטים נוספים.</translation>
<translation id="5690972056512883402">‏יש ללחוץ על השם שלך כדי לפתוח את WEB3 DNA Browser ולהתחיל לגלוש.</translation>
<translation id="5645023388974281920">‏המשתמש <ph name="EXISTING_USER" /> כבר מחובר לפרופיל WEB3 DNA Browser הזה. כדי להפריד בין פעילויות גלישה, WEB3 DNA Browser יכול ליצור עבורך פרופיל משלך.</translation>
<translation id="8552133641824014764">‏החשבון שלך מנוהל על ידי <ph name="MANAGER_NAME" />. האדמין שלך יכול לראות ולערוך את הפרופיל הזה של דפדפן WEB3 DNA Browser ואת הנתונים שלו, כמו סימניות, היסטוריה וסיסמאות.</translation>
<translation id="1745190996116952155">‏WEB3 DNA Browser מנסה להעתיק את הסיסמאות. כדי לאפשר למערכת לעשות זאת, יש להזין את הסיסמה שלך ל-Windows.</translation>
<translation id="2363126436977372294">‏ההמלצה של WEB3 DNA Browser היא לסרוק את הקובץ הזה כי הוא עלול להיות מסוכן</translation>
